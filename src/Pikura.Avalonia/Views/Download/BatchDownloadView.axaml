<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Pikura.Avalonia.ViewModels"
             xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="Pikura.Avalonia.Views.BatchDownloadView"
             x:DataType="vm:BatchDownloadViewModel">

    <Design.DataContext>
        <vm:BatchDownloadViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10"
                Margin="0,32,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- LEFT: Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Batch Download" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- CENTER: Spacer -->
                <Border Grid.Column="1"/>

                <!-- RIGHT: Queue button -->
                <Button Grid.Column="2"
                        Command="{Binding OpenQueueCommand}"
                        CornerRadius="6" Padding="12,8" FontSize="12"
                        ToolTip.Tip="Download Queue">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Queue" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Tabbed Content -->
        <TabControl Grid.Row="1" Padding="0" TabStripPlacement="Top" Margin="0">
            <TabItem Header="👤 By Artist">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="20">
                        <!-- Artist Selection -->
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="Selected Artists" FontSize="15" FontWeight="SemiBold"
                                                   AutomationProperties.Name="Selected Artists Header"
                                                   AutomationProperties.HelpText="List of artists selected for download"/>
                                        <TextBlock Text="{Binding ArtistViewModel.SelectedArtists.Count, StringFormat='{}{0} artists'}"
                                                   FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"
                                                   AutomationProperties.Name="{Binding ArtistViewModel.SelectedArtists.Count, StringFormat='{}{0} artists selected'}"/>
                                        <TextBlock Text="•"
                                                   FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"
                                                   IsVisible="{Binding ArtistViewModel.SelectedArtists.Count}"/>
                                        <TextBlock Text="{Binding ArtistViewModel.EstimatedItemCount, StringFormat='~{}{0} items'}"
                                                   FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"
                                                   IsVisible="{Binding ArtistViewModel.SelectedArtists.Count}"
                                                   AutomationProperties.Name="{Binding ArtistViewModel.EstimatedItemCount, StringFormat='Approximately {0} items to download'}"/>
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="🗑 Clear all"
                                            Command="{Binding ArtistViewModel.ClearArtistsCommand}"
                                            IsVisible="{Binding ArtistViewModel.SelectedArtists.Count}"
                                            ToolTip.Tip="Remove all selected artists"
                                            CornerRadius="6" Padding="10,4" FontSize="12"/>
                                </DockPanel>

                                <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Height="150">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ArtistViewModel.SelectedArtists}" Margin="8">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:SelectedArtist">
                                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                            BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                                            BorderThickness="1" CornerRadius="6"
                                                            Padding="8,4" Margin="0,0,6,6">
                                                        <DockPanel LastChildFill="False">
                                                            <Button DockPanel.Dock="Right" Content="✕"
                                                                    FontSize="10" CornerRadius="3" Padding="4,0" Margin="6,0,0,0"
                                                                    ToolTip.Tip="Remove artist"
                                                                    Command="{Binding $parent[ItemsControl].DataContext.ArtistViewModel.RemoveArtistCommand}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Button DockPanel.Dock="Right" Content="⚙"
                                                                    FontSize="10" CornerRadius="3" Padding="4,0" Margin="6,0,0,0"
                                                                    ToolTip.Tip="Configure custom download settings for this artist"
                                                                    Command="{Binding $parent[ItemsControl].DataContext.ArtistViewModel.ConfigureArtistSettingsCommand}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Border DockPanel.Dock="Right" IsVisible="{Binding HasCustomSettings}"
                                                                    Background="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"
                                                                    CornerRadius="3" Padding="3,0" Margin="6,0,0,0"
                                                                    ToolTip.Tip="Has custom download settings">
                                                                <TextBlock Text="●" FontSize="10" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding UserName}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="+ Add Followed Artists"
                                            Command="{Binding ArtistViewModel.AddFollowedArtistsCommand}"
                                            ToolTip.Tip="Add all artists you follow on Pixiv to the download list"
                                            CornerRadius="6" Padding="12,8"/>
                                    <Button Content="📁 Import from File"
                                            Command="{Binding ArtistViewModel.ImportArtistsFromFileAsync}"
                                            ToolTip.Tip="Import a list of artist IDs from a text file (one per line)"
                                            CornerRadius="6" Padding="12,8"/>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" Text="Artist IDs or URLs" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding ArtistViewModel.ParsedArtistIds.Count, StringFormat='{}{0} IDs detected'}"
                                                   FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"/>
                                    </DockPanel>

                                    <TextBox Text="{Binding ArtistViewModel.NewArtistId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Watermark="Enter artist IDs or URLs...&#x0a;One per line or comma-separated&#x0a;Example: 1234567&#x0a;https://www.pixiv.net/en/users/1234567"
                                             CornerRadius="6" MinHeight="80"
                                             AutomationProperties.Name="Artist ID or URL Input"
                                             AutomationProperties.HelpText="Enter Pixiv artist IDs or profile URLs. Multiple IDs can be entered separated by commas or new lines."
                                             KeyboardNavigation.TabIndex="1"/>

                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <Button Content="📋 Paste"
                                                Command="{Binding ArtistViewModel.PasteFromClipboardCommand}"
                                                ToolTip.Tip="Paste last copied ID"
                                                CornerRadius="6" Padding="10,6"
                                                IsVisible="{Binding ArtistViewModel.HasClipboardContent}"/>
                                        <Button Content="✕ Clear"
                                                Command="{Binding ArtistViewModel.ClearInputCommand}"
                                                ToolTip.Tip="Clear the input box"
                                                CornerRadius="6" Padding="10,6"
                                                IsVisible="{Binding ArtistViewModel.ParsedArtistIds.Count}"/>
                                        <Button Content="+ Add Artists"
                                                Command="{Binding ArtistViewModel.AddArtistByIdCommand}"
                                                IsEnabled="{Binding ArtistViewModel.ParsedArtistIds.Count}"
                                                ToolTip.Tip="Add artists by ID or Pixiv profile URL"
                                                CornerRadius="6" Padding="12,6"
                                                AutomationProperties.Name="Add Artists Button"
                                                AutomationProperties.HelpText="Click to add all valid artist IDs entered above"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Artist Preview Card -->
                                <Border IsVisible="{Binding ArtistViewModel.ShowArtistPreview}"
                                        Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <!-- Avatar -->
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                Background="{actipro:ThemeResource Container2BackgroundBrush}">
                                            <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding ArtistViewModel.PreviewArtistName}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding ArtistViewModel.PreviewArtistId, StringFormat='ID: {0}'}"
                                                       FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        </StackPanel>

                                        <!-- Add Button -->
                                        <Button Grid.Column="2" Content="+ Add"
                                                Command="{Binding ArtistViewModel.AddArtistByIdCommand}"
                                                CornerRadius="6" Padding="12,6"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Page Range Settings -->
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Default Page Range (All Artists)" FontSize="15" FontWeight="SemiBold"
                                           ToolTip.Tip="Specify which pages to download: 0 = all, 1-5 = range, 2,4,6 = specific pages"/>

                                <StackPanel Spacing="4">
                                    <TextBox Text="{Binding ArtistViewModel.DefaultPageRange, Mode=TwoWay}"
                                             CornerRadius="6" Width="200" HorizontalAlignment="Left"
                                             Watermark="e.g., 0, 1-5, 2,4,6-10"
                                             ToolTip.Tip="Enter page numbers: 0 or 'all' for all pages, '1-5' for range, '2,4,6' for specific pages"/>
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"
                                               TextWrapping="Wrap"
                                               Text="Format: 0 or 'all' = all pages, '2' = page 2, '1-5' = pages 1-5, '2,4,6-10' = specific pages"/>
                                </StackPanel>

                                <TextBlock IsVisible="{Binding ArtistViewModel.DefaultPageRangeInvalid}"
                                           Text="⚠ Invalid format. Use: 0, 2, 1-5, or 2,4,6-10"
                                           FontSize="12" Foreground="Orange"/>

                                <CheckBox Content="Set custom page ranges and settings per artist"
                                          IsChecked="{Binding ArtistViewModel.UsePerArtistPageRanges, Mode=TwoWay}"
                                          ToolTip.Tip="Enable to set different page ranges and per-artist download settings"/>

                                <!-- Per-Artist Page Ranges + Settings (visible when enabled) -->
                                <Border IsVisible="{Binding ArtistViewModel.UsePerArtistPageRanges}"
                                        Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="8">
                                    <StackPanel>
                                        <!-- Header row -->
                                        <Grid ColumnDefinitions="*,120,Auto" ColumnSpacing="8" Margin="4,4,4,4">
                                            <TextBlock Grid.Column="0" Text="Artist" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                            <TextBlock Grid.Column="1" Text="Page Range" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                            <TextBlock Grid.Column="2" Text="Custom Settings" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding ArtistViewModel.SelectedArtists}"
                                                      Margin="4,0,4,4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:SelectedArtist">
                                                    <Grid ColumnDefinitions="*,120,Auto" ColumnSpacing="8" Margin="0,4">
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding UserName}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <Border IsVisible="{Binding HasCustomSettings}"
                                                                    Background="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"
                                                                    CornerRadius="3" Padding="4,1"
                                                                    ToolTip.Tip="Has custom download settings">
                                                                <TextBlock Text="Custom" FontSize="10"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding PageRange, Mode=TwoWay}"
                                                                 Watermark="Default"
                                                                 CornerRadius="4"
                                                                 FontSize="12"/>
                                                        <Button Grid.Column="2"
                                                                Content="⚙ Settings"
                                                                FontSize="11" CornerRadius="4"
                                                                Padding="8,4"
                                                                ToolTip.Tip="Configure custom download settings for this artist"
                                                                Command="{Binding $parent[ItemsControl].DataContext.ArtistViewModel.ConfigureArtistSettingsCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Settings Section -->
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Download Settings" FontSize="15" FontWeight="SemiBold"/>

                                <StackPanel Spacing="8">
                                    <RadioButton Content="Use global settings"
                                                 IsChecked="{Binding ArtistViewModel.UseGlobalSettings, Mode=TwoWay}"/>
                                    <RadioButton Content="Use custom settings for this download"
                                                 IsChecked="{Binding !ArtistViewModel.UseGlobalSettings, Mode=TwoWay}"/>
                                </StackPanel>

                                <!-- Custom Settings Panel -->
                                <StackPanel IsVisible="{Binding !ArtistViewModel.UseGlobalSettings}" Spacing="10">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                        <StackPanel Grid.Column="0" Spacing="6">
                                            <TextBlock Text="Folder Template" FontSize="12"/>
                                            <TextBox Text="{Binding ArtistViewModel.CustomSettings.FolderTemplate, Mode=TwoWay}"
                                                     CornerRadius="4" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock Text="Filename Template" FontSize="12"/>
                                            <TextBox Text="{Binding ArtistViewModel.CustomSettings.FilenameTemplate, Mode=TwoWay}"
                                                     CornerRadius="4" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <CheckBox Content="Create subfolder per submission"
                                                  IsChecked="{Binding ArtistViewModel.CustomSettings.CreateSubfolderPerSubmission, Mode=TwoWay}"
                                                  ToolTip.Tip="Create a separate folder for each artwork/download"
                                                  FontSize="12"/>
                                        <CheckBox Content="Separate R-18 folder"
                                                  IsChecked="{Binding ArtistViewModel.CustomSettings.SeparateR18Folder, Mode=TwoWay}"
                                                  ToolTip.Tip="Save R-18 (mature) content to a separate folder"
                                                  FontSize="12"/>
                                    </StackPanel>

                                    <!-- Content Filters -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Content Filters" FontSize="12" FontWeight="SemiBold"/>
                                        <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                                BorderThickness="1" CornerRadius="6" Padding="12,10">
                                            <StackPanel Spacing="10">

                                                <TextBlock Text="Skip content types:" FontSize="11"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                <WrapPanel>
                                                    <CheckBox Content="AI-generated" Margin="0,0,16,4"
                                                              IsChecked="{Binding ArtistViewModel.CustomSettings.FilterAiGenerated, Mode=TwoWay}"
                                                              FontSize="12"/>
                                                    <CheckBox Content="Manga" Margin="0,0,16,4"
                                                              IsChecked="{Binding ArtistViewModel.CustomSettings.SkipManga, Mode=TwoWay}"
                                                              FontSize="12"/>
                                                    <CheckBox Content="Ugoira" Margin="0,0,16,4"
                                                              IsChecked="{Binding ArtistViewModel.CustomSettings.SkipUgoira, Mode=TwoWay}"
                                                              FontSize="12"/>
                                                    <CheckBox Content="R-18" Margin="0,0,16,4"
                                                              IsChecked="{Binding ArtistViewModel.CustomSettings.SkipR18, Mode=TwoWay}"
                                                              FontSize="12"/>
                                                    <CheckBox Content="R-18G only" Margin="0,0,0,4"
                                                              IsChecked="{Binding ArtistViewModel.CustomSettings.SkipR18G, Mode=TwoWay}"
                                                              FontSize="12"
                                                              ToolTip.Tip="Skip grotesque/violent R-18G but still download regular R-18"/>
                                                </WrapPanel>

                                                <!-- Tag filters -->
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <TextBlock Text="Must include tag(s)" FontSize="11"/>
                                                        <TextBox Text="{Binding ArtistViewModel.CustomSettings.IncludeTags, Mode=TwoWay}"
                                                                 Watermark="e.g. original, fantasy"
                                                                 CornerRadius="4" FontSize="12"
                                                                 ToolTip.Tip="Comma-separated. Artwork must match at least one."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="Exclude tag(s)" FontSize="11"/>
                                                        <TextBox Text="{Binding ArtistViewModel.CustomSettings.ExcludeTagsFilter, Mode=TwoWay}"
                                                                 Watermark="e.g. guro, furry"
                                                                 CornerRadius="4" FontSize="12"
                                                                 ToolTip.Tip="Comma-separated. Artwork is skipped if it has any of these."/>
                                                    </StackPanel>
                                                </Grid>

                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Auto-Retry Settings -->
                                    <StackPanel Spacing="8">
                                        <CheckBox Content="Auto-retry failed downloads"
                                                  IsChecked="{Binding ArtistViewModel.CustomSettings.AutoRetryFailedDownloads, Mode=TwoWay}"
                                                  ToolTip.Tip="Automatically retry failed downloads with the configured delay"
                                                  FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" Spacing="16" IsVisible="{Binding ArtistViewModel.CustomSettings.AutoRetryFailedDownloads}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Max Retries" FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                <NumericUpDown Value="{Binding ArtistViewModel.CustomSettings.MaxRetryAttempts, Mode=TwoWay}"
                                                               Minimum="1" Maximum="10"
                                                               Width="80" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Retry Delay (sec)" FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                <NumericUpDown Value="{Binding ArtistViewModel.CustomSettings.RetryDelaySeconds, Mode=TwoWay}"
                                                               Minimum="1" Maximum="60"
                                                               Width="100" FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Progress Section (visible when downloading) -->
                        <Border IsVisible="{Binding ArtistViewModel.HasActiveJob}"
                                Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ProgressBar Value="{Binding ArtistViewModel.ProgressPercent}"
                                                Maximum="100"
                                                Width="300"
                                                Height="8"
                                                CornerRadius="4"
                                                ShowProgressText="False"
                                                IsIndeterminate="{Binding ArtistViewModel.IsLoading}"
                                                AutomationProperties.Name="Download Progress"
                                                AutomationProperties.HelpText="Shows the current download progress"/>
                                    <TextBlock Text="{Binding ArtistViewModel.ProgressPercent, StringFormat='{}{0:F0}%'}"
                                               FontSize="13" VerticalAlignment="Center"
                                               AutomationProperties.Name="{Binding ArtistViewModel.ProgressPercent, StringFormat='Download is {0:F0} percent complete'}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ArtistViewModel.ProgressStatusMessage}"
                                           FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                           TextTrimming="CharacterEllipsis"
                                           AutomationProperties.Name="{Binding ArtistViewModel.ProgressStatusMessage}"/>
                                <TextBlock Text="{Binding ArtistViewModel.CompletedItemCount, StringFormat='Completed {0} of {1} items', TargetNullValue='Starting...'}"
                                           FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"
                                           IsVisible="{Binding ArtistViewModel.EstimatedItemCount}"/>
                            </StackPanel>
                        </Border>

                        <!-- Download Preview (visible when not downloading) -->
                        <Border IsVisible="{Binding !ArtistViewModel.HasActiveJob}"
                                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📊" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ArtistViewModel.DownloadPreviewText}"
                                           FontSize="13"
                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                           VerticalAlignment="Center"
                                           AutomationProperties.Name="Download Preview"
                                           AutomationProperties.HelpText="Shows what will be downloaded"/>
                            </StackPanel>
                        </Border>

                        <!-- Action Bar -->
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                                <Button Content="💾 Save"
                                        Command="{Binding ArtistViewModel.SavePresetCommand}"
                                        ToolTip.Tip="Save current artist list and settings as a reusable preset"
                                        CornerRadius="6" Padding="12,8"
                                        AutomationProperties.Name="Save Preset Button"
                                        AutomationProperties.HelpText="Save current configuration for later use"
                                        KeyboardNavigation.TabIndex="10"/>
                                <Button Content="📂 Load"
                                        Command="{Binding ArtistViewModel.LoadPresetCommand}"
                                        ToolTip.Tip="Load a previously saved preset with artist list and settings"
                                        CornerRadius="6" Padding="12,8"
                                        AutomationProperties.Name="Load Preset Button"
                                        AutomationProperties.HelpText="Load a previously saved configuration"
                                        KeyboardNavigation.TabIndex="11"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                                <Button Content="+ Add to Queue"
                                        Command="{Binding ArtistViewModel.AddToQueueCommand}"
                                        IsEnabled="{Binding ArtistViewModel.SelectedArtists.Count}"
                                        CornerRadius="6" Padding="14,12" FontWeight="SemiBold"
                                        ToolTip.Tip="Add to queue without starting immediately — start from the Queue window"
                                        KeyboardNavigation.TabIndex="19"/>
                                <Button Content="▶ Start Download"
                                        Command="{Binding ArtistViewModel.StartDownloadCommand}"
                                        IsEnabled="{Binding ArtistViewModel.SelectedArtists.Count}"
                                        Classes="accent"
                                        CornerRadius="6" Padding="20,12" FontWeight="SemiBold"
                                        ToolTip.Tip="Begin downloading artworks from all selected artists immediately"
                                        AutomationProperties.Name="Start Download Button"
                                        AutomationProperties.HelpText="Click to begin downloading from all selected artists"
                                        KeyboardNavigation.TabIndex="20"/>
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="🖼️ By Image ID">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="20">
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="Image IDs or URLs" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ImageIdViewModel.ParsedIds.Count, StringFormat='{}{0} IDs detected'}"
                                               FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"/>
                                </DockPanel>

                                <TextBox Text="{Binding ImageIdViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Watermark="Enter image IDs, URLs...&#x0a;One per line or comma-separated&#x0a;Example: 12345678&#x0a;https://www.pixiv.net/en/artworks/12345678"
                                         Height="200"
                                         CornerRadius="6"
                                         FontFamily="Consolas, monospace"
                                         FontSize="13"/>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="📁 Import from File"
                                            Command="{Binding ImageIdViewModel.ImportFromFileAsync}"
                                            CornerRadius="6" Padding="12,8"/>
                                    <Button Content="Clear"
                                            Command="{Binding ImageIdViewModel.ClearInputCommand}"
                                            CornerRadius="6" Padding="12,8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button Content="▶ Start Image ID Download"
                                Command="{Binding ImageIdViewModel.StartDownloadCommand}"
                                IsEnabled="{Binding ImageIdViewModel.ParsedIds.Count}"
                                Classes="accent"
                                HorizontalAlignment="Right"
                                CornerRadius="6" Padding="20,12" FontWeight="SemiBold"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="🔖 Bookmarks">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="20">
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Source" FontSize="15" FontWeight="SemiBold"/>
                                <RadioButton Content="Bookmarked Images (Illustrations/Manga)"
                                             IsChecked="{Binding BookmarksViewModel.IsBookmarkedImages, Mode=TwoWay}"/>
                                <RadioButton Content="Bookmarked Artists"
                                             IsChecked="{Binding !BookmarksViewModel.IsBookmarkedImages, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Visibility" FontSize="15" FontWeight="SemiBold"/>
                                <StackPanel Spacing="8">
                                    <RadioButton Content="Public bookmarks only"
                                                 IsChecked="{Binding BookmarksViewModel.IsPublicOnly, Mode=TwoWay}"/>
                                    <RadioButton Content="Private bookmarks only"
                                                 IsChecked="{Binding BookmarksViewModel.IsPrivateOnly, Mode=TwoWay}"/>
                                    <RadioButton Content="Both public and private"
                                                 IsChecked="{Binding BookmarksViewModel.IsBothVisibility, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Filter Options" FontSize="15" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <CheckBox Content="Include R-18" IsChecked="{Binding BookmarksViewModel.IncludeR18, Mode=TwoWay}"/>
                                    <CheckBox Content="Include AI-generated" IsChecked="{Binding BookmarksViewModel.IncludeAiGenerated, Mode=TwoWay}"/>
                                    <CheckBox Content="Include Manga" IsChecked="{Binding BookmarksViewModel.IncludeManga, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button Content="▶ Start Remote Bookmark Download"
                                Command="{Binding BookmarksViewModel.StartDownloadCommand}"
                                Classes="accent"
                                HorizontalAlignment="Right"
                                CornerRadius="6" Padding="20,12" FontWeight="SemiBold"
                                ToolTip.Tip="Download from Pixiv bookmarks (Public/Private)"/>

                        <!-- Local Favorites Download Options -->
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Local Favorites" FontSize="15" FontWeight="SemiBold"/>
                                <StackPanel Spacing="8">
                                    <Button Content="↓ Download All Favorites"
                                            Command="{Binding BookmarksViewModel.DownloadAllFavoritesCommand}"
                                            CornerRadius="6" Padding="12,6" FontSize="12"
                                            HorizontalAlignment="Stretch"/>
                                    
                                    <StackPanel Spacing="4" IsVisible="{Binding BookmarksViewModel.HasFolders}">
                                        <TextBlock Text="Download from folder:" FontSize="12"
                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding BookmarksViewModel.AvailableFolders}"
                                                      SelectedItem="{Binding BookmarksViewModel.SelectedFolder, Mode=TwoWay}"
                                                      PlaceholderText="Select folder..."
                                                      CornerRadius="6" Padding="8,4" FontSize="12"/>
                                            <Button Grid.Column="1" Content="Download"
                                                    Command="{Binding BookmarksViewModel.DownloadFromFolderCommand}"
                                                    CornerRadius="6" Padding="12,6" FontSize="12"
                                                    Margin="8,0,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <CheckBox Content="Use custom download path"
                                                  IsChecked="{Binding BookmarksViewModel.UseCustomDownloadPath, Mode=TwoWay}"/>
                                        <TextBox Text="{Binding BookmarksViewModel.CustomDownloadPath, Mode=TwoWay}"
                                                 PlaceholderText="Custom download path..."
                                                 CornerRadius="6" Padding="8,4" FontSize="12"
                                                 IsEnabled="{Binding BookmarksViewModel.UseCustomDownloadPath}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="📋 From List">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="20">
                        <TextBlock Text="📋 Download from List" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Download from list.txt or tags.txt files&#x0a;Import URLs, IDs, or tags from a text file"
                                   TextAlignment="Center" Opacity="0.7"/>
                        
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                                    <TextBox Grid.Column="0" 
                                             Text="{Binding FromListViewModel.SelectedFilePath, Mode=OneWay}"
                                             PlaceholderText="No file selected..."
                                             IsReadOnly="True"
                                             CornerRadius="6" Padding="8,4" FontSize="12"/>
                                    <Button Grid.Column="1" Content="📁 Browse"
                                            Command="{Binding FromListViewModel.SelectListFileCommand}"
                                            CornerRadius="6" Padding="12,6" FontSize="12"
                                            Margin="8,0,0,0"/>
                                </Grid>
                                
                                <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12"
                                        MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding FromListViewModel.ListContent}" 
                                                   FontSize="11" 
                                                   FontFamily="Consolas,monospace"
                                                   TextWrapping="Wrap"
                                                   Opacity="0.9"/>
                                    </ScrollViewer>
                                </Border>
                                
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Items:" FontSize="12" 
                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                    <TextBlock Text="{Binding FromListViewModel.ItemCount}" 
                                               FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Content="Clear" 
                                            Command="{Binding FromListViewModel.ClearListCommand}"
                                            CornerRadius="6" Padding="12,6" FontSize="12"/>
                                    <Button Content="▶ Start Download" 
                                            Command="{Binding FromListViewModel.StartDownloadCommand}"
                                            Classes="accent"
                                            IsEnabled="{Binding FromListViewModel.HasItems}"
                                            CornerRadius="6" Padding="16,6" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="🔍 Search">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="20">
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Search Keyword" FontSize="14" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding SearchViewModel.SearchKeyword, Mode=TwoWay}"
                                         PlaceholderText="Enter search keyword..."
                                         CornerRadius="6" Padding="8,4" FontSize="12"/>
                                
                                <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Mode" FontSize="12" 
                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        <ComboBox SelectedValue="{Binding SearchViewModel.SearchMode, Mode=TwoWay}"
                                                  SelectedValueBinding="{ReflectionBinding Tag}"
                                                  CornerRadius="6" FontSize="12">
                                            <ComboBoxItem Content="Safe" Tag="safe"/>
                                            <ComboBoxItem Content="R-18" Tag="r18"/>
                                            <ComboBoxItem Content="All" Tag="all"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
                                        <TextBlock Text="Sort Order" FontSize="12" 
                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        <ComboBox SelectedValue="{Binding SearchViewModel.SortOrder, Mode=TwoWay}"
                                                  SelectedValueBinding="{ReflectionBinding Tag}"
                                                  CornerRadius="6" FontSize="12">
                                            <ComboBoxItem Content="Newest First" Tag="date_d"/>
                                            <ComboBoxItem Content="Popular First" Tag="popular_d"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4" Margin="8,0,0,0">
                                        <TextBlock Text="Max Results" FontSize="12" 
                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        <NumericUpDown Value="{Binding SearchViewModel.MaxResults, Mode=TwoWay}"
                                                     Minimum="1" Maximum="500"
                                                     CornerRadius="6" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Button Content="🔍 Search"
                                        Command="{Binding SearchViewModel.SearchCommand}"
                                        IsEnabled="{Binding !SearchViewModel.IsSearching}"
                                        CornerRadius="6" Padding="12,6" FontSize="12"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16"
                                IsVisible="{Binding SearchViewModel.HasResults}">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Results" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SearchViewModel.ResultCount, StringFormat='{}{0} items'}"
                                               FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                </Grid>
                                
                                <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                        BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12"
                                        MaxHeight="400">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding SearchViewModel.SearchResults}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                            BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                                            BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,8,8"
                                                            Width="150">
                                                        <StackPanel Spacing="6">
                                                            <!-- Thumbnail -->
                                                            <Border BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                                                    BorderThickness="1" CornerRadius="4"
                                                                    Height="150" Background="{actipro:ThemeResource Container3BackgroundBrush}">
                                                                <Image Source="{Binding Thumbnail}"
                                                                       Stretch="UniformToFill"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                            </Border>
                                                            <!-- Info -->
                                                            <TextBlock Text="{Binding Title}" FontSize="11" 
                                                                       TextTrimming="CharacterEllipsis" MaxLines="2"/>
                                                            <TextBlock Text="{Binding ArtistName}" FontSize="10"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="{Binding PageCount, StringFormat='{}{0}p'}" FontSize="9"
                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                                <TextBlock Text="•" FontSize="9"
                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                           IsVisible="{Binding IsR18}"/>
                                                                <TextBlock Text="R-18" FontSize="9" Foreground="Red"
                                                                           IsVisible="{Binding IsR18}"/>
                                                                <TextBlock Text="•" FontSize="9"
                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                           IsVisible="{Binding IsAiGenerated}"/>
                                                                <TextBlock Text="AI" FontSize="9" Foreground="Orange"
                                                                           IsVisible="{Binding IsAiGenerated}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Content="Clear Results" 
                                            Command="{Binding SearchViewModel.ClearResultsCommand}"
                                            CornerRadius="6" Padding="12,6" FontSize="12"/>
                                    <Button Content="▶ Start Download" 
                                            Command="{Binding SearchViewModel.StartDownloadCommand}"
                                            Classes="accent"
                                            CornerRadius="6" Padding="16,6" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="📦 FANBOX">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="20">
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Search by Post ID" FontSize="14" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding FanboxViewModel.PostId, Mode=TwoWay}"
                                             PlaceholderText="Enter FANBOX post ID..."
                                             CornerRadius="6" Padding="8,4" FontSize="12"/>
                                    <Button Grid.Column="1" Content="🔍 Search"
                                            Command="{Binding FanboxViewModel.SearchByPostIdCommand}"
                                            IsEnabled="{Binding !FanboxViewModel.IsSearching}"
                                            CornerRadius="6" Padding="12,6" FontSize="12" Margin="8,0,0,0"/>
                                </Grid>
                                <Separator/>
                                <TextBlock Text="Search by Creator ID" FontSize="14" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding FanboxViewModel.CreatorId, Mode=TwoWay}"
                                             PlaceholderText="Enter creator ID..."
                                             CornerRadius="6" Padding="8,4" FontSize="12"/>
                                    <Button Grid.Column="1" Content="🔍 Search"
                                            Command="{Binding FanboxViewModel.SearchByCreatorIdCommand}"
                                            IsEnabled="{Binding !FanboxViewModel.IsSearching}"
                                            CornerRadius="6" Padding="12,6" FontSize="12" Margin="8,0,0,0"/>
                                </Grid>
                                <TextBlock Text="{Binding FanboxViewModel.SearchResult}"
                                           FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16"
                                IsVisible="{Binding FanboxViewModel.Posts.Count}">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Results" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding FanboxViewModel.Posts.Count, StringFormat='{}{0} posts'}"
                                               FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                </Grid>
                                
                                <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                        BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12"
                                        MaxHeight="300">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding FanboxViewModel.Posts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                            BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                                            BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,4">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Post.Title}" FontSize="12" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Post.User.Name, StringFormat='{}By {0}'}" FontSize="11"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            <TextBlock Text="{Binding Post.PublishedDatetime, StringFormat='{}{0:yyyy-MM-dd}'}" FontSize="10"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            <TextBlock Text="{Binding Post.Images.Count, StringFormat='{}{0} images'}" FontSize="10"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            <Separator Margin="0,4,0,4"/>
                                                            <TextBlock Text="Cover Filename:" FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            <TextBlock Text="{Binding CoverFilename}" FontSize="9"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="Info Filename:" FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            <TextBlock Text="{Binding InfoFilename}" FontSize="9"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="Image Filenames:" FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            <ItemsControl ItemsSource="{Binding ImageFilenames}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding}" FontSize="9"
                                                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Content="Clear Results" 
                                            Command="{Binding FanboxViewModel.ClearResultsCommand}"
                                            CornerRadius="6" Padding="12,6" FontSize="12"/>
                                    <Button Content="▶ Download" 
                                            Command="{Binding FanboxViewModel.DownloadSelectedCommand}"
                                            Classes="accent"
                                            CornerRadius="6" Padding="16,6" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- ====================== SCHEDULES ====================== -->
            <TabItem Header="⏰ Schedules">
                <Grid RowDefinitions="*">
                    <!-- Single unified view: List or Editor based on IsEditing -->
                    <Grid RowDefinitions="Auto,*">
                        <!-- Toolbar -->
                        <Border Grid.Row="0" Padding="16,10"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}" BorderThickness="0,0,0,1">
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SchedulesViewModel.Schedules.Count, StringFormat='{}{0} schedules'}"
                                               FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding !SchedulesViewModel.IsEditing}"/>
                                    <TextBlock Text="{Binding SchedulesViewModel.StatusMessage}"
                                               FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding SchedulesViewModel.StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                                    <!-- Show when NOT editing -->
                                    <Button Content="+ New Schedule"
                                            Command="{Binding SchedulesViewModel.AddNewCommand}"
                                            IsVisible="{Binding !SchedulesViewModel.IsEditing}"
                                            Classes="accent"
                                            CornerRadius="6" Padding="12,6" FontSize="12"/>
                                    <Button Content="↺ Refresh"
                                            Command="{Binding SchedulesViewModel.RefreshCommand}"
                                            IsVisible="{Binding !SchedulesViewModel.IsEditing}"
                                            CornerRadius="6" Padding="10,4" FontSize="12"/>
                                    <!-- Show when editing -->
                                    <Button Content="← Back to Schedules"
                                            Command="{Binding SchedulesViewModel.CancelEditCommand}"
                                            IsVisible="{Binding SchedulesViewModel.IsEditing}"
                                            CornerRadius="6" Padding="10,6" FontSize="12"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Content area -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="0">
                                <!-- Schedule LIST (visible when not editing) -->
                                <StackPanel Spacing="0" Margin="16,12"
                                            IsVisible="{Binding !SchedulesViewModel.IsEditing}">
                                <ItemsControl ItemsSource="{Binding SchedulesViewModel.Schedules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ScheduleRowViewModel">
                                            <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                    BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="12,10" Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                                    <!-- Enable toggle -->
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                              VerticalAlignment="Center" Margin="0,0,12,0"
                                                              Command="{Binding $parent[ItemsControl].DataContext.SchedulesViewModel.ToggleEnabledCommand}"
                                                              CommandParameter="{Binding}"/>
                                                    <!-- Info -->
                                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                                            <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                                                    CornerRadius="3" Padding="5,1">
                                                                <TextBlock Text="{Binding TypeLabel}" FontSize="10"
                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            </Border>
                                                            <Border Background="#1A7F37" CornerRadius="3" Padding="5,1"
                                                                    IsVisible="{Binding IsRunning}">
                                                                <TextBlock Text="● Running" FontSize="10" Foreground="#3FB950"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                            <TextBlock Text="{Binding TriggerLabel}" FontSize="11"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            <TextBlock Text="{Binding ArtistsSummary}" FontSize="11"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                       IsVisible="{Binding HasArtists}"
                                                                       TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                            <TextBlock Text="{Binding LastRun, StringFormat='Last: {0}'}" FontSize="10"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"/>
                                                            <TextBlock Text="{Binding NextRun, StringFormat='Next: {0}'}" FontSize="10"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding LastError, StringFormat='⚠ {0}'}" FontSize="10"
                                                                   Foreground="OrangeRed" IsVisible="{Binding HasError}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <!-- Edit -->
                                                    <Button Grid.Column="2" Content="✏ Edit"
                                                            FontSize="11" CornerRadius="4" Padding="8,4" Margin="6,0,0,0"
                                                            ToolTip.Tip="Edit this schedule"
                                                            Command="{Binding $parent[ItemsControl].DataContext.SchedulesViewModel.BeginEditCommand}"
                                                            CommandParameter="{Binding}"/>
                                                    <!-- Run Now -->
                                                    <Button Grid.Column="3" Content="▶ Run"
                                                            FontSize="11" CornerRadius="4" Padding="8,4" Margin="4,0,0,0"
                                                            ToolTip.Tip="Run this schedule immediately"
                                                            Command="{Binding $parent[ItemsControl].DataContext.SchedulesViewModel.RunNowCommand}"
                                                            CommandParameter="{Binding}"/>
                                                    <!-- Delete -->
                                                    <Button Grid.Column="4" Content="🗑"
                                                            FontSize="11" CornerRadius="4" Padding="6,4" Margin="4,0,0,0"
                                                            ToolTip.Tip="Delete this schedule"
                                                            Command="{Binding $parent[ItemsControl].DataContext.SchedulesViewModel.DeleteScheduleCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No schedules yet. Click '+ New Schedule' to create one."
                                           FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                           IsVisible="{Binding !SchedulesViewModel.Schedules.Count}"
                                           Margin="0,8"/>
                            </StackPanel>

                            <!-- Schedule EDITOR (visible when editing) -->
                            <StackPanel Spacing="16" Margin="20"
                                        IsVisible="{Binding SchedulesViewModel.IsEditing}">

                                    <!-- Schedule name -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Schedule Name" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBox Text="{Binding SchedulesViewModel.NewScheduleName, Mode=TwoWay}"
                                                 Watermark="e.g. My Fav Artists Daily (auto-generated if blank)"
                                                 CornerRadius="6" FontSize="12"/>
                                    </StackPanel>

                                    <!-- Artists in this schedule -->
                                    <StackPanel Spacing="8">
                                        <DockPanel LastChildFill="False">
                                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text="Artists" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding SchedulesViewModel.StagedArtists.Count, StringFormat='{}{0} added'}"
                                                           FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button DockPanel.Dock="Right" Content="✕ Clear all"
                                                    Command="{Binding SchedulesViewModel.ClearStagedArtistsCommand}"
                                                    IsVisible="{Binding SchedulesViewModel.HasStagedArtists}"
                                                    CornerRadius="4" Padding="8,3" FontSize="11"/>
                                        </DockPanel>
                                        <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                                BorderThickness="1" CornerRadius="6" MinHeight="40" Padding="6">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                                                <ItemsControl ItemsSource="{Binding SchedulesViewModel.StagedArtists}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="vm:StagedArtist">
                                                            <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                    BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                                                    BorderThickness="1" CornerRadius="5"
                                                                    Padding="8,3" Margin="0,0,5,5">
                                                                <DockPanel LastChildFill="False">
                                                                    <Button DockPanel.Dock="Right" Content="✕"
                                                                            FontSize="9" CornerRadius="2" Padding="3,0" Margin="5,0,0,0"
                                                                            Command="{Binding $parent[ItemsControl].DataContext.SchedulesViewModel.RemoveArtistFromStagingCommand}"
                                                                            CommandParameter="{Binding}"/>
                                                                    <TextBlock Text="{Binding DisplayLabel}" FontSize="11" VerticalAlignment="Center"/>
                                                                </DockPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding SchedulesViewModel.NewArtistId, Mode=TwoWay}"
                                                     Watermark="Artist ID or pixiv.net/en/users/123…"
                                                     CornerRadius="6" FontSize="12"/>
                                            <TextBox Grid.Column="1" Width="80"
                                                     Text="{Binding SchedulesViewModel.PageRange, Mode=TwoWay}"
                                                     Watermark="Pages"
                                                     ToolTip.Tip="Page range for this artist, e.g. 0 = all, 1-5 = range"
                                                     CornerRadius="6" FontSize="12"/>
                                            <Button Grid.Column="2" Content="+ Add"
                                                    Command="{Binding SchedulesViewModel.AddArtistToStagingCommand}"
                                                    IsEnabled="{Binding !SchedulesViewModel.IsResolvingArtist}"
                                                    CornerRadius="6" Padding="10,6" FontSize="12"
                                                    ToolTip.Tip="Resolve artist name and add to list"/>
                                        </Grid>
                                        <TextBlock Text="{Binding SchedulesViewModel.ResolveError}"
                                                   FontSize="11" Foreground="OrangeRed"
                                                   IsVisible="{Binding SchedulesViewModel.ResolveError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>

                                    <!-- When to Run -->
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="When to Run" FontSize="12" FontWeight="SemiBold"/>
                                        <StackPanel Spacing="6">
                                            <RadioButton Content="Daily / recurring" GroupName="TriggerType"
                                                         IsChecked="{Binding SchedulesViewModel.IsTriggerDaily, Mode=TwoWay}" FontSize="12"/>
                                            <RadioButton Content="Run on app startup" GroupName="TriggerType"
                                                         IsChecked="{Binding SchedulesViewModel.IsTriggerStartup, Mode=TwoWay}" FontSize="12"/>
                                            <RadioButton Content="Run once at a specific date &amp; time" GroupName="TriggerType"
                                                         IsChecked="{Binding SchedulesViewModel.IsTriggerOnce, Mode=TwoWay}" FontSize="12"/>
                                        </StackPanel>
                                        <Border IsVisible="{Binding SchedulesViewModel.IsTriggerDaily}"
                                                Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                                BorderThickness="1" CornerRadius="6" Padding="12,10">
                                            <StackPanel Spacing="8">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="Time:" FontSize="12" VerticalAlignment="Center"/>
                                                    <ComboBox ItemsSource="{Binding SchedulesViewModel.Hour12Options}"
                                                              SelectedItem="{Binding SchedulesViewModel.TriggerHour12, Mode=TwoWay}"
                                                              FontSize="12" Width="65" ToolTip.Tip="Hour (1–12)"/>
                                                    <TextBlock Text=":" FontSize="14" VerticalAlignment="Center"/>
                                                    <ComboBox ItemsSource="{Binding SchedulesViewModel.MinuteOptions}"
                                                              SelectedItem="{Binding SchedulesViewModel.TriggerMinute, Mode=TwoWay}"
                                                              FontSize="12" Width="65" ToolTip.Tip="Minute"/>
                                                    <ComboBox ItemsSource="{Binding SchedulesViewModel.AmPmOptions}"
                                                              SelectedItem="{Binding SchedulesViewModel.TriggerAmPm, Mode=TwoWay}"
                                                              FontSize="12" Width="65"/>
                                                    <TextBlock Text="Checks/day:" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                    <ComboBox Width="55" SelectedItem="{Binding SchedulesViewModel.ChecksPerDay, Mode=TwoWay}"
                                                              FontSize="12" ToolTip.Tip="1 = once daily, 2 = twice (every 12 h), 3 = three times (every 8 h)">
                                                        <ComboBoxItem Content="1"/>
                                                        <ComboBoxItem Content="2"/>
                                                        <ComboBoxItem Content="3"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <TextBlock FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"
                                                           Text="2× = every 12 h  ·  3× = every 8 h, spread from the selected time"/>
                                            </StackPanel>
                                        </Border>
                                        <Border IsVisible="{Binding SchedulesViewModel.IsTriggerOnce}"
                                                Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                                BorderThickness="1" CornerRadius="6" Padding="12,10">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Run once on:" FontSize="12"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <CalendarDatePicker SelectedDate="{Binding SchedulesViewModel.OnceDateTime, Mode=TwoWay}"
                                                                        FontSize="12" Width="160" ToolTip.Tip="Pick the date"/>
                                                    <ComboBox ItemsSource="{Binding SchedulesViewModel.Hour12Options}"
                                                              SelectedItem="{Binding SchedulesViewModel.TriggerHour12, Mode=TwoWay}"
                                                              FontSize="12" Width="65" ToolTip.Tip="Hour"/>
                                                    <TextBlock Text=":" FontSize="14" VerticalAlignment="Center"/>
                                                    <ComboBox ItemsSource="{Binding SchedulesViewModel.MinuteOptions}"
                                                              SelectedItem="{Binding SchedulesViewModel.TriggerMinute, Mode=TwoWay}"
                                                              FontSize="12" Width="65" ToolTip.Tip="Minute"/>
                                                    <ComboBox ItemsSource="{Binding SchedulesViewModel.AmPmOptions}"
                                                              SelectedItem="{Binding SchedulesViewModel.TriggerAmPm, Mode=TwoWay}"
                                                              FontSize="12" Width="65"/>
                                                </StackPanel>
                                                <TextBlock FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"
                                                           Text="The schedule will run exactly once and then be marked expired."/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Content Filters -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Content Filters" FontSize="12" FontWeight="SemiBold"/>
                                        <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                                BorderThickness="1" CornerRadius="6" Padding="12,10">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="Skip content types:" FontSize="11"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                <WrapPanel>
                                                    <CheckBox Content="AI-generated" Margin="0,0,16,4"
                                                              IsChecked="{Binding SchedulesViewModel.FilterSkipAi, Mode=TwoWay}" FontSize="12"/>
                                                    <CheckBox Content="Manga" Margin="0,0,16,4"
                                                              IsChecked="{Binding SchedulesViewModel.FilterSkipManga, Mode=TwoWay}" FontSize="12"/>
                                                    <CheckBox Content="Ugoira" Margin="0,0,16,4"
                                                              IsChecked="{Binding SchedulesViewModel.FilterSkipUgoira, Mode=TwoWay}" FontSize="12"/>
                                                    <CheckBox Content="R-18" Margin="0,0,16,4"
                                                              IsChecked="{Binding SchedulesViewModel.FilterSkipR18, Mode=TwoWay}" FontSize="12"/>
                                                    <CheckBox Content="R-18G only" Margin="0,0,0,4"
                                                              IsChecked="{Binding SchedulesViewModel.FilterSkipR18G, Mode=TwoWay}" FontSize="12"
                                                              ToolTip.Tip="Skip grotesque/violent R-18G but still download regular R-18"/>
                                                </WrapPanel>
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Only download artworks posted:" FontSize="11"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                    <ComboBox SelectedIndex="{Binding SchedulesViewModel.FilterDateLimitMode, Mode=TwoWay}"
                                                              CornerRadius="4" FontSize="12" HorizontalAlignment="Left" MinWidth="180">
                                                        <ComboBoxItem Content="All time"/>
                                                        <ComboBoxItem Content="Since last run"/>
                                                        <ComboBoxItem Content="Within the last 24 hours"/>
                                                        <ComboBoxItem Content="Within the last 7 days"/>
                                                        <ComboBoxItem Content="Within the last 30 days"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Max artworks per artist:" FontSize="11"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                    <TextBox Text="{Binding SchedulesViewModel.FilterMaxArtworks, Mode=TwoWay}"
                                                             Watermark="e.g. 10  (leave blank for all)"
                                                             CornerRadius="4" FontSize="12" HorizontalAlignment="Left" MinWidth="180"
                                                             ToolTip.Tip="Only fetch the N most-recent artworks per artist. Leave blank or 0 for no limit."/>
                                                </StackPanel>
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <TextBlock Text="Must include tag(s)" FontSize="11"/>
                                                        <TextBox Text="{Binding SchedulesViewModel.FilterIncludeTags, Mode=TwoWay}"
                                                                 Watermark="e.g. original, fantasy" CornerRadius="4" FontSize="12"
                                                                 ToolTip.Tip="Comma-separated. Artwork must match at least one."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="Exclude tag(s)" FontSize="11"/>
                                                        <TextBox Text="{Binding SchedulesViewModel.FilterExcludeTags, Mode=TwoWay}"
                                                                 Watermark="e.g. guro, furry" CornerRadius="4" FontSize="12"
                                                                 ToolTip.Tip="Comma-separated. Artwork is skipped if it has any of these."/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Naming Overrides -->
                                    <Expander Header="📁 Naming Overrides (optional)" FontSize="12">
                                        <StackPanel Spacing="10" Margin="0,8,0,0">
                                            <CheckBox Content="Override global folder / filename templates for this schedule"
                                                      IsChecked="{Binding SchedulesViewModel.UseCustomNaming, Mode=TwoWay}" FontSize="12"/>
                                            <StackPanel IsVisible="{Binding SchedulesViewModel.UseCustomNaming}" Spacing="8">
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <TextBlock Text="Folder Template" FontSize="12"/>
                                                        <TextBox Text="{Binding SchedulesViewModel.CustomFolderTemplate, Mode=TwoWay}"
                                                                 Watermark="Leave blank for global" CornerRadius="4" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="Filename Template" FontSize="12"/>
                                                        <TextBox Text="{Binding SchedulesViewModel.CustomFilenameTemplate, Mode=TwoWay}"
                                                                 Watermark="Leave blank for global" CornerRadius="4" FontSize="12"/>
                                                    </StackPanel>
                                                </Grid>
                                                <CheckBox Content="Separate R-18 into subfolder"
                                                          IsChecked="{Binding SchedulesViewModel.CustomSeparateR18, Mode=TwoWay}" FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>

                                    <!-- Save / Cancel -->
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <Button Content="← Back to Schedules"
                                                Command="{Binding SchedulesViewModel.CancelEditCommand}"
                                                CornerRadius="6" Padding="12,8" FontSize="13"/>
                                        <Button Content="{Binding SchedulesViewModel.AddButtonLabel}"
                                                Command="{Binding SchedulesViewModel.AddScheduleCommand}"
                                                Classes="accent"
                                                CornerRadius="6" Padding="16,8" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>

                                </StackPanel>
                            </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
