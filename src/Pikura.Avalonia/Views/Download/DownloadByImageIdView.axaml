<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Pikura.Avalonia.ViewModels"
             xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Pikura.Avalonia.Views.DownloadByImageIdView"
             x:DataType="vm:DownloadByImageIdViewModel"
             x:Name="ThisView">

    <Design.DataContext>
        <vm:DownloadByImageIdViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Download by Image ID" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Download specific artworks by their ID or URL"
                               FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="? Help" CornerRadius="6" Padding="12,6"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Margin="20">

                <!-- Image IDs Input -->
                <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Image IDs or URLs"
                                       FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ParsedIds.Count, StringFormat='{}{0} IDs detected'}"
                                       FontSize="13"
                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                        </Grid>

                        <TextBox Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Watermark="Enter image IDs, URLs, or paste from clipboard...&#x0a;Examples:&#x0a;12345678&#x0a;https://www.pixiv.net/en/artworks/12345678&#x0a;12345679, 12345680"
                                 Height="200"
                                 CornerRadius="6"
                                 FontFamily="Consolas, monospace"
                                 FontSize="13"/>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="📋 Paste from Clipboard"
                                    Click="OnPasteClicked"
                                    CornerRadius="6" Padding="12,8"/>
                            <Button Content="📁 Import from File"
                                    Command="{Binding ImportFromFileCommand}"
                                    CornerRadius="6" Padding="12,8"/>
                            <Button Content="Clear"
                                    Command="{Binding ClearInputCommand}"
                                    CornerRadius="6" Padding="12,8"/>
                        </StackPanel>

                        <!-- Validation Summary -->
                        <Border IsVisible="{Binding HasInvalidInput}"
                                Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="⚠ Some entries could not be parsed:"
                                           FontSize="12" Foreground="Orange"/>
                                <TextBlock Text="{Binding InvalidEntriesSummary}"
                                           FontSize="11"
                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Download Options -->
                <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Download Options" FontSize="15" FontWeight="SemiBold"/>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Page Range (for multi-page works)"
                                       FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                            <ComboBox ItemsSource="{Binding PageRangeOptions}"
                                      SelectedItem="{Binding SelectedPageRange, Mode=TwoWay}"
                                      Width="200" HorizontalAlignment="Left"
                                      CornerRadius="6"/>
                            <TextBlock Text="Single-page artworks will download the full image regardless of this setting."
                                       FontSize="11"
                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"/>
                        </StackPanel>

                        <CheckBox Content="Skip already downloaded images"
                                  IsChecked="{Binding SkipExisting, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <!-- Settings Override -->
                <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Download Settings" FontSize="15" FontWeight="SemiBold"/>

                        <StackPanel Spacing="8">
                            <RadioButton Content="Use global settings"
                                          IsChecked="{Binding UseGlobalSettings, Mode=TwoWay}"/>
                            <RadioButton Content="Use custom settings for this download"
                                          IsChecked="{Binding !UseGlobalSettings, Mode=TwoWay}"/>
                        </StackPanel>

                        <!-- Custom Settings Panel -->
                        <StackPanel IsVisible="{Binding !UseGlobalSettings}" Spacing="10">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Folder Template" FontSize="12"/>
                                    <TextBox Text="{Binding CustomSettings.FolderTemplate, Mode=TwoWay}"
                                             CornerRadius="4"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Filename Template" FontSize="12"/>
                                    <TextBox Text="{Binding CustomSettings.FilenameTemplate, Mode=TwoWay}"
                                             CornerRadius="4"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Progress Panel -->
        <Border Grid.Row="2" Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16"
                IsVisible="{Binding HasActiveJob}">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProgressPercent, StringFormat='{}{0:F0}%'}"
                               FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="4"/>
                <TextBlock Text="{Binding CurrentItemName}"
                           FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                           IsVisible="{Binding CurrentItemName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>
        </Border>

        <!-- Action Bar -->
        <Border Grid.Row="3" Background="{actipro:ThemeResource Container2BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <Button Grid.Column="0" Content="💾 Save Preset"
                        Command="{Binding SavePresetCommand}"
                        CornerRadius="6" Padding="12,8"/>

                <Button Grid.Column="1" Content="Cancel"
                        Command="{Binding CancelDownloadCommand}"
                        IsVisible="{Binding HasActiveJob}"
                        CornerRadius="6" Padding="16,10" Margin="0,0,8,0"/>

                <Button Grid.Column="2" Content="▶ Start Download"
                        Command="{Binding StartDownloadCommand}"
                        IsEnabled="{Binding ParsedIds.Count}"
                        IsVisible="{Binding !HasActiveJob}"
                        Classes="accent"
                        CornerRadius="6" Padding="20,12" FontWeight="SemiBold"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
