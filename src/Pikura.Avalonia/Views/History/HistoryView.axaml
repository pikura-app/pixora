<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
             xmlns:vm="using:Pikura.Avalonia.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Pikura.Avalonia.Views.History.HistoryView"
             x:DataType="vm:HistoryViewModel">

    <Design.DataContext>
        <vm:HistoryViewModel/>
    </Design.DataContext>


    <UserControl.Styles>
        <!-- Neutralize ListBox selection/hover chrome so grouped history rows
             render like plain cards (no selection highlight). -->
        <Style Selector="ListBox.history">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBox.history ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.history ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.history ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10"
                Margin="0,32,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="📜 History" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="View active and archived downloads"
                               FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="🔄 Refresh"
                            Command="{Binding RefreshCommand}"
                            CornerRadius="6" Padding="12,8"/>
                    <Button Content="🔄 Retry All Failed"
                            Command="{Binding RetryAllFailedCommand}"
                            IsVisible="{Binding FailedJobs.Count}"
                            CornerRadius="6" Padding="12,8" Classes="accent"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs: Active / Completed / Failed / Cancelled -->
        <TabControl Grid.Row="1" Padding="0" TabStripPlacement="Top">

            <!-- ── Active ── -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="⏳ Active"/>
                        <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                CornerRadius="8" Padding="5,1"
                                IsVisible="{Binding ActiveJobs.Count}">
                            <TextBlock Text="{Binding ActiveJobs.Count}" FontSize="11" Foreground="DodgerBlue"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,8" BorderBrush="{actipro:ThemeResource Container2BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding ActiveJobs.Count, StringFormat='{}{0} active'}"
                                       FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                                        IsVisible="{Binding ActiveJobs.Count}">
                                <Button Content="⏸ Pause All"
                                        Command="{Binding PauseAllCommand}"
                                        CornerRadius="6" Padding="10,6" FontSize="12"/>
                                <Button Content="▶ Resume All"
                                        Command="{Binding ResumeAllCommand}"
                                        CornerRadius="6" Padding="10,6" FontSize="12" Classes="accent"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16,12">
                            <ItemsControl x:Name="ActiveJobsList" ItemsSource="{Binding ActiveJobs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:DownloadJobViewModel">
                                        <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                                BorderThickness="1" CornerRadius="6" Margin="0,0,0,6"
                                                ClipToBounds="True">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="⏸ Pause"
                                                              Command="{Binding PauseCommand}"
                                                              IsVisible="{Binding IsPausable}"/>
                                                    <MenuItem Header="▶ Resume"
                                                              Command="{Binding ResumeCommand}"
                                                              IsVisible="{Binding IsResumable}"/>
                                                    <MenuItem Header="✖ Cancel"
                                                              Command="{Binding CancelCommand}"
                                                              IsVisible="{Binding IsCancellable}"/>
                                                    <Separator/>
                                                    <MenuItem Header="⬆ Move to Top"    Command="{Binding MoveToTopCommand}"/>
                                                    <MenuItem Header="↑ Move Up"         Command="{Binding MoveUpCommand}"/>
                                                    <MenuItem Header="↓ Move Down"       Command="{Binding MoveDownCommand}"/>
                                                    <MenuItem Header="⬇ Move to Bottom"  Command="{Binding MoveToBottomCommand}"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Grid Grid.Column="0" Width="64" Height="64">
                                                    <Border CornerRadius="5,0,0,5" ClipToBounds="True"
                                                            Background="{actipro:ThemeResource Container2BackgroundBrush}">
                                                        <Panel>
                                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" IsVisible="{Binding HasThumbnail}"/>
                                                            <ProgressBar IsIndeterminate="True" Height="3" VerticalAlignment="Bottom" IsVisible="{Binding !HasThumbnail}"/>
                                                        </Panel>
                                                    </Border>
                                                    <!-- Queue position badge -->
                                                    <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                                                            Background="#CC000000" CornerRadius="0,0,4,0"
                                                            Padding="5,2" IsHitTestVisible="False">
                                                        <TextBlock Text="{Binding QueuePosition}" FontSize="10"
                                                                   FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                                <Grid Grid.Column="1" ColumnDefinitions="Auto,*" Margin="10,6,10,6">
                                                    <Border Grid.Column="0" Width="48" Height="48"
                                                            CornerRadius="4" ClipToBounds="True" Margin="0,0,8,0"
                                                            Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                            IsVisible="{Binding HasCurrentFile}">
                                                        <Panel>
                                                            <Image Source="{Binding CurrentFileThumbnail}" Stretch="UniformToFill"
                                                                   IsVisible="{Binding CurrentFileThumbnail, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                            <ProgressBar IsIndeterminate="True" Height="3" VerticalAlignment="Bottom"
                                                                         IsVisible="{Binding CurrentFileThumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        </Panel>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Job.Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                        <TextBlock Text="{Binding CurrentArtist}" FontSize="11"
                                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                   IsVisible="{Binding CurrentArtist, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                        <TextBlock Text="{Binding CurrentFileLabel}" FontSize="11"
                                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushSecondary}"
                                                                   IsVisible="{Binding HasCurrentFile}"
                                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                        <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="4" CornerRadius="2" Margin="0,2,0,0"/>
                                                        <ProgressBar Value="{Binding CurrentFilePct}" Maximum="100" Height="3" CornerRadius="2"
                                                                     IsVisible="{Binding HasCurrentFile}" Opacity="0.6"/>
                                                    </StackPanel>
                                                </Grid>
                                                <StackPanel Grid.Column="2" Spacing="6" Margin="0,0,14,0" VerticalAlignment="Center" HorizontalAlignment="Right" MinWidth="90">
                                                    <TextBlock Text="{Binding StatusText}" FontSize="12" HorizontalAlignment="Right" FontWeight="Medium"/>
                                                    <TextBlock FontSize="11" HorizontalAlignment="Right"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                               IsVisible="{Binding TotalCount}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} / {1}">
                                                                <Binding Path="CompletedCount"/>
                                                                <Binding Path="TotalCount"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <StackPanel Spacing="5" Margin="0,4,0,0">
                                                        <Button Content="⏸ Pause" Command="{Binding PauseCommand}"
                                                                IsVisible="{Binding IsPausable}"
                                                                CornerRadius="6" Padding="10,5" FontSize="11"
                                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                        <Button Content="▶ Resume" Command="{Binding ResumeCommand}"
                                                                IsVisible="{Binding IsResumable}"
                                                                CornerRadius="6" Padding="10,5" FontSize="11"
                                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                Classes="accent"/>
                                                        <Button Content="✖ Cancel" Command="{Binding CancelCommand}"
                                                                IsVisible="{Binding IsCancellable}"
                                                                CornerRadius="6" Padding="10,5" FontSize="11"
                                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No active downloads" FontSize="13"
                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                       IsVisible="{Binding !ActiveJobs.Count}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ── Completed ── -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="✅ Completed"/>
                        <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                CornerRadius="8" Padding="5,1"
                                IsVisible="{Binding CompletedJobs.Count}">
                            <TextBlock Text="{Binding CompletedJobs.Count}" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,8" BorderBrush="{actipro:ThemeResource Container2BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding CompletedJobs.Count, StringFormat='{}{0} jobs'}"
                                       FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="🗑 Clear All"
                                    Command="{Binding ClearCompletedCommand}"
                                    IsVisible="{Binding CompletedJobs.Count}"
                                    CornerRadius="6" Padding="10,4" FontSize="11"/>
                        </DockPanel>
                    </Border>
                    <Panel Grid.Row="1">
                        <ListBox Classes="history" ItemsSource="{Binding CompletedView}"
                                 Padding="16,12" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.DataTemplates>
                                <DataTemplate DataType="vm:HistoryGroupViewModel">
                                    <Button Command="{Binding ToggleCommand}"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Padding="4,10,4,4" Margin="0,0,0,2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                        <Grid ColumnDefinitions="16,Auto,*">
                                            <TextBlock Grid.Column="0" Text="{Binding Chevron}" FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontWeight="SemiBold" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                                       Margin="10,0,0,0" VerticalAlignment="Center"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                                <DataTemplate DataType="vm:DownloadJobViewModel">
                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,8" ClipToBounds="True">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="72" Height="72" CornerRadius="5,0,0,5" ClipToBounds="True"
                                                    Background="{actipro:ThemeResource Container3BackgroundBrush}">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" IsVisible="{Binding HasThumbnail}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="3" Margin="12,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Job.Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <TextBlock FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} • {1:MMM d, yyyy HH:mm}">
                                                            <Binding Path="TypeLabel"/>
                                                            <Binding Path="Job.CompletedAt"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="{Binding ArtistInfo}" FontSize="11"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                           IsVisible="{Binding HasArtistInfo}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <TextBlock Text="{Binding ResultSummary}" FontSize="11"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}" FontSize="12" HorizontalAlignment="Right"/>
                                                <Button Content="📂 Open Folder" Command="{Binding OpenFolderCommand}"
                                                        IsVisible="{Binding HasOutputFolder}"
                                                        CornerRadius="6" Padding="8,4" FontSize="11"/>
                                                <Button Content="✖ Remove"
                                                        Command="{Binding $parent[ListBox].DataContext.RemoveJobCommand}"
                                                        CommandParameter="{Binding}"
                                                        CornerRadius="6" Padding="8,4" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.DataTemplates>
                        </ListBox>
                        <TextBlock Text="No completed downloads" FontSize="13"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                   IsVisible="{Binding !CompletedJobs.Count}"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0"/>
                    </Panel>
                </Grid>
            </TabItem>

            <!-- ── Failed ── -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="❌ Failed"/>
                        <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                CornerRadius="8" Padding="5,1"
                                IsVisible="{Binding FailedJobs.Count}">
                            <TextBlock Text="{Binding FailedJobs.Count}" FontSize="11" Foreground="OrangeRed"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,8" BorderBrush="{actipro:ThemeResource Container2BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding FailedJobs.Count, StringFormat='{}{0} jobs'}"
                                       FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                                <Button Content="� Retry All"
                                        Command="{Binding RetryAllFailedCommand}"
                                        IsVisible="{Binding FailedJobs.Count}"
                                        CornerRadius="6" Padding="10,4" FontSize="11" Classes="accent"/>
                                <Button Content="🗑 Clear All"
                                        Command="{Binding ClearFailedCommand}"
                                        IsVisible="{Binding FailedJobs.Count}"
                                        CornerRadius="6" Padding="10,4" FontSize="11"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Panel Grid.Row="1">
                        <ListBox Classes="history" ItemsSource="{Binding FailedView}"
                                 Padding="16,12" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.DataTemplates>
                                <DataTemplate DataType="vm:HistoryGroupViewModel">
                                    <Button Command="{Binding ToggleCommand}"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Padding="4,10,4,4" Margin="0,0,0,2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                        <Grid ColumnDefinitions="16,Auto,*">
                                            <TextBlock Grid.Column="0" Text="{Binding Chevron}" FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontWeight="SemiBold" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                                       Margin="10,0,0,0" VerticalAlignment="Center"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                                <DataTemplate DataType="vm:DownloadJobViewModel">
                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,8" ClipToBounds="True">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="72" Height="72" CornerRadius="5,0,0,5" ClipToBounds="True"
                                                    Background="{actipro:ThemeResource Container3BackgroundBrush}">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" IsVisible="{Binding HasThumbnail}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="3" Margin="12,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Job.Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <TextBlock FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} • {1:MMM d, yyyy HH:mm}">
                                                            <Binding Path="TypeLabel"/>
                                                            <Binding Path="Job.CompletedAt"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="{Binding ArtistInfo}" FontSize="11"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                           IsVisible="{Binding HasArtistInfo}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <TextBlock Text="{Binding ResultSummary}" FontSize="11" Foreground="OrangeRed"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}" FontSize="12" HorizontalAlignment="Right" Foreground="OrangeRed"/>
                                                <Button Content="🔄 Retry"
                                                        Command="{Binding $parent[ListBox].DataContext.RetryJobCommand}"
                                                        CommandParameter="{Binding}"
                                                        CornerRadius="6" Padding="8,4" FontSize="11" Classes="accent"/>
                                                <Button Content="✖ Remove"
                                                        Command="{Binding $parent[ListBox].DataContext.RemoveJobCommand}"
                                                        CommandParameter="{Binding}"
                                                        CornerRadius="6" Padding="8,4" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.DataTemplates>
                        </ListBox>
                        <TextBlock Text="No failed downloads" FontSize="13"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                   IsVisible="{Binding !FailedJobs.Count}"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0"/>
                    </Panel>
                </Grid>
            </TabItem>

            <!-- ── Cancelled ── -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="🚫 Cancelled"/>
                        <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                CornerRadius="8" Padding="5,1"
                                IsVisible="{Binding CancelledJobs.Count}">
                            <TextBlock Text="{Binding CancelledJobs.Count}" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,8" BorderBrush="{actipro:ThemeResource Container2BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding CancelledJobs.Count, StringFormat='{}{0} jobs'}"
                                       FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="🗑 Clear All"
                                    Command="{Binding ClearCancelledCommand}"
                                    IsVisible="{Binding CancelledJobs.Count}"
                                    CornerRadius="6" Padding="10,4" FontSize="11"/>
                        </DockPanel>
                    </Border>
                    <Panel Grid.Row="1">
                        <ListBox Classes="history" ItemsSource="{Binding CancelledView}"
                                 Padding="16,12" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.DataTemplates>
                                <DataTemplate DataType="vm:HistoryGroupViewModel">
                                    <Button Command="{Binding ToggleCommand}"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Padding="4,10,4,4" Margin="0,0,0,2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                        <Grid ColumnDefinitions="16,Auto,*">
                                            <TextBlock Grid.Column="0" Text="{Binding Chevron}" FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontWeight="SemiBold" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="11"
                                                       Margin="10,0,0,0" VerticalAlignment="Center"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                                <DataTemplate DataType="vm:DownloadJobViewModel">
                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,8" ClipToBounds="True">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Width="72" Height="72" CornerRadius="5,0,0,5" ClipToBounds="True"
                                                    Background="{actipro:ThemeResource Container3BackgroundBrush}">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" IsVisible="{Binding HasThumbnail}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="3" Margin="12,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Job.Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <TextBlock FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} • {1:MMM d, yyyy HH:mm}">
                                                            <Binding Path="TypeLabel"/>
                                                            <Binding Path="Job.CompletedAt"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="{Binding ArtistInfo}" FontSize="11"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                           IsVisible="{Binding HasArtistInfo}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <TextBlock Text="{Binding ResultSummary}" FontSize="11"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}" FontSize="12" HorizontalAlignment="Right"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                <Button Content="🔄 Retry"
                                                        Command="{Binding $parent[ListBox].DataContext.RetryJobCommand}"
                                                        CommandParameter="{Binding}"
                                                        CornerRadius="6" Padding="8,4" FontSize="11" Classes="accent"/>
                                                <Button Content="✖ Remove"
                                                        Command="{Binding $parent[ListBox].DataContext.RemoveJobCommand}"
                                                        CommandParameter="{Binding}"
                                                        CornerRadius="6" Padding="8,4" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.DataTemplates>
                        </ListBox>
                        <TextBlock Text="No cancelled downloads" FontSize="13"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                   IsVisible="{Binding !CancelledJobs.Count}"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0"/>
                    </Panel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
