<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
             xmlns:vm="using:Pikura.Avalonia.ViewModels"
             xmlns:conv="using:Pikura.Avalonia.Converters"
             xmlns:local="using:Pikura.Avalonia.Views.Gallery"
             x:DataType="vm:DiscoverViewModel"
             x:Class="Pikura.Avalonia.Views.Discover.DiscoverView">

    <UserControl.Resources>
        <conv:BoolToBlurRadiusConverter x:Key="BoolToBlurRadiusConverter"/>

        <ContextMenu x:Key="ArtworkCardContextMenu" x:DataType="vm:ArtworkCardViewModel">
            <ContextMenu.Styles>
                <Style Selector="ContextMenu">
                    <Setter Property="Background" Value="{actipro:ThemeResource Container1BackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{actipro:ThemeResource DefaultForegroundBrush}"/>
                </Style>
                <Style Selector="MenuItem">
                    <Setter Property="Foreground" Value="{actipro:ThemeResource DefaultForegroundBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="MenuItem:pointerover">
                    <Setter Property="Background" Value="{actipro:ThemeResource ControlBackgroundBrushSoftAccent}"/>
                </Style>
                <Style Selector="Separator">
                    <Setter Property="Background" Value="{actipro:ThemeResource Container1BorderBrush}"/>
                </Style>
            </ContextMenu.Styles>
            <MenuItem Header="👁 Open in side panel" Click="OnContextPreview"/>
            <MenuItem Header="⛶ Open full screen" Click="OnContextOpenFullScreen"/>
            <MenuItem Header="⊞ Open in new tab" Click="OnContextOpenInNewTab"/>
            <MenuItem Header="⧉ Open in popup window" Click="OnContextOpenPopup"/>
            <Separator/>
            <MenuItem Header="↓ Download" Click="OnContextDownload"/>
            <Separator/>
            <MenuItem Header="👤 Open artist gallery" Click="OnContextOpenArtistGallery"/>
            <MenuItem Header="🌐 Open on pixiv.net" Click="OnContextOpenPixiv"/>
            <MenuItem Header="🌐 Open artist on pixiv" Click="OnContextOpenArtist"/>
            <Separator/>
            <MenuItem Header="★ Add to favorites" Click="OnContextToggleFavorite" IsVisible="{Binding !IsLocalFavorite}"/>
            <MenuItem Header="★ Remove from favorites" Click="OnContextToggleFavorite" IsVisible="{Binding IsLocalFavorite}"/>
            <Separator/>
            <MenuItem Header="Copy artwork ID" Click="OnContextCopyId"/>
            <MenuItem Header="Copy artwork URL" Click="OnContextCopyUrl"/>
            <MenuItem Header="📋 Copy image" Click="OnContextCopyImage"/>
        </ContextMenu>

        <ContextMenu x:Key="UserCardContextMenu" x:DataType="vm:DiscoveryUserCardViewModel">
            <ContextMenu.Styles>
                <Style Selector="ContextMenu">
                    <Setter Property="Background" Value="{actipro:ThemeResource Container1BackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{actipro:ThemeResource DefaultForegroundBrush}"/>
                </Style>
                <Style Selector="MenuItem">
                    <Setter Property="Foreground" Value="{actipro:ThemeResource DefaultForegroundBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="MenuItem:pointerover">
                    <Setter Property="Background" Value="{actipro:ThemeResource ControlBackgroundBrushSoftAccent}"/>
                </Style>
            </ContextMenu.Styles>
            <MenuItem Header="👤 Open artist gallery" Click="OnContextUserOpenGallery"/>
            <MenuItem Header="🌐 Open on pixiv.net" Click="OnContextUserOpenPixiv"/>
            <Separator/>
            <MenuItem Header="Copy artist ID" Click="OnContextUserCopyId"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto"
          Background="{actipro:ThemeResource Container3BackgroundBrush}">

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1"
                Margin="0,32,0,0"
                Padding="12,7">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <ToggleButton IsChecked="{Binding IsWorksTab}"
                                  Command="{Binding SetTabIndexCommand}" CommandParameter="0"
                                  CornerRadius="6" Padding="10,5" FontSize="12">Works</ToggleButton>
                    <ToggleButton IsChecked="{Binding IsUsersTab}"
                                  Command="{Binding SetTabIndexCommand}" CommandParameter="1"
                                  CornerRadius="6" Padding="10,5" FontSize="12">Users</ToggleButton>
                    <Rectangle Width="1" Height="18" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="4,0"/>
                    <Button CornerRadius="6" Padding="10,5" FontSize="12"
                            Command="{Binding RefreshCommand}"
                            ToolTip.Tip="Refresh">⟳ Refresh</Button>
                    <Button CornerRadius="6" Padding="10,5" FontSize="12"
                            Command="{Binding CopyAllArtistIdsCommand}"
                            IsVisible="{Binding IsUsersTab}"
                            ToolTip.Tip="Click individual artist IDs to queue them, then press this to copy all queued IDs at once">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="📋 Copy All" FontSize="12"/>
                            <TextBlock Text="{Binding QueuedArtistCount, StringFormat='({0})'}" FontSize="12"
                                       IsVisible="{Binding QueuedArtistCount, Converter={x:Static conv:GreaterThanZeroConverter.Instance}}"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Height="18" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="4,0"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding IsGridView}">
                        <Button CornerRadius="6" Padding="8,4" FontSize="11"
                                Command="{Binding SetFixedHeightCommand}"
                                IsEnabled="{Binding !IsFixedHeight}"
                                ToolTip.Tip="Fixed card height">Fixed</Button>
                        <Button CornerRadius="6" Padding="8,4" FontSize="11"
                                Command="{Binding SetNaturalHeightCommand}"
                                IsEnabled="{Binding !IsNaturalHeight}"
                                ToolTip.Tip="Natural height (preserves aspect ratio)">Natural</Button>
                        <Rectangle Width="1" Height="16" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>
                    </StackPanel>
                    <ToggleButton IsChecked="{Binding ShowTags, Mode=TwoWay}"
                                  CornerRadius="6" Padding="8,4" FontSize="11"
                                  ToolTip.Tip="Show/hide tag chips">🏷 Tags</ToggleButton>
                    <ToggleButton IsChecked="{Binding ShowInfo, Mode=TwoWay}"
                                  CornerRadius="6" Padding="8,4" FontSize="11"
                                  ToolTip.Tip="Show/hide title + artist">ℹ Info</ToggleButton>
                    <ToggleButton IsChecked="{Binding ShowPreview, Mode=TwoWay}"
                                  CornerRadius="6" Padding="8,4" FontSize="11"
                                  ToolTip.Tip="Toggle the side panel">▣ Side Panel</ToggleButton>
                    <Rectangle Width="1" Height="16" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"
                               IsVisible="{Binding ShowR18Buttons}"/>
                    <ToggleButton IsChecked="{Binding ShowR18, Mode=TwoWay}"
                                  CornerRadius="6" Padding="8,4" FontSize="11"
                                  IsVisible="{Binding ShowR18Buttons}"
                                  ToolTip.Tip="Show / hide R-18 content">
                        <ToggleButton.Styles>
                            <Style Selector="ToggleButton:checked">
                                <Setter Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </ToggleButton.Styles>
                        🔞 R-18
                    </ToggleButton>
                    <Rectangle Width="1" Height="16" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>
                    <TextBlock Text="Size" FontSize="11" VerticalAlignment="Center" Opacity="0.7"/>
                    <Slider Minimum="120" Maximum="320" Value="{Binding CardSize, Mode=TwoWay}"
                            Width="80" VerticalAlignment="Center" Margin="4,0"
                            ToolTip.Tip="{Binding CardSize, StringFormat='Card size: {0}px'}"/>
                    <Rectangle Width="1" Height="16" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>
                    <Button CornerRadius="6" Padding="8,4" FontSize="11"
                            Command="{Binding SetGridViewCommand}" IsEnabled="{Binding !IsGridView}"
                            ToolTip.Tip="Grid view">⊞ Grid</Button>
                    <Button CornerRadius="6" Padding="8,4" FontSize="11"
                            Command="{Binding SetListViewCommand}" IsEnabled="{Binding !IsListView}"
                            ToolTip.Tip="List view">≡ List</Button>
                    <Rectangle Width="1" Height="16" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>
                    <Button Content="☑ Select All" CornerRadius="6" Padding="10,6" FontSize="11"
                            Command="{Binding SelectAllCommand}" ToolTip.Tip="Select all visible artworks"/>
                    <Button Content="☒ Deselect All" CornerRadius="6" Padding="10,6" FontSize="11"
                            Command="{Binding ClearSelectionCommand}"
                            IsVisible="{Binding HasSelection}" ToolTip.Tip="Clear selection"/>
                    <Button CornerRadius="6" Padding="10,6" FontSize="11"
                            Classes.accent="{Binding HasSelection}"
                            IsEnabled="{Binding HasSelection}"
                            Command="{Binding DownloadSelectedCommand}"
                            ToolTip.Tip="Download selected artworks">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="↓" FontSize="12"/>
                            <TextBlock Text="{Binding SelectedCount, StringFormat='Download Selected ({0})'}" />
                        </StackPanel>
                    </Button>
                    <Button CornerRadius="6" Padding="10,6" FontSize="11"
                            Command="{Binding DownloadVisibleCommand}"
                            ToolTip.Tip="Download all visible artworks">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="⊞" FontSize="12"/>
                            <TextBlock Text="Download Visible"/>
                        </StackPanel>
                    </Button>
                    <Button Content="🎨 Download Preset" CornerRadius="6" Padding="10,6" FontSize="11"
                            Click="OnDownloadPresetClicked"
                            IsEnabled="{Binding !IsLoading}"
                            ToolTip.Tip="Download with image processing preset"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ── Content area ── -->
        <Grid Grid.Row="1">

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Works Tab ── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Grid IsVisible="{Binding IsWorksTab}">

                <!-- Loading spinner -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsVisible="{Binding IsLoading}" Spacing="8" ZIndex="2">
                    <ProgressBar IsIndeterminate="True" Width="60"/>
                    <TextBlock Text="Loading…" FontSize="13" Opacity="0.7" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Empty / error state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                            IsVisible="{Binding !HasRecommendedWorks}">
                    <TextBlock Text="No recommended works" FontSize="14" Opacity="0.6" HorizontalAlignment="Center"
                               IsVisible="{Binding !IsLoading}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.5" HorizontalAlignment="Center"
                               IsVisible="{Binding !IsLoading}"/>
                    <Button Content="⟳ Retry" HorizontalAlignment="Center"
                            Command="{Binding LoadRecommendedWorksCommand}"
                            IsVisible="{Binding !IsLoading}" CornerRadius="6" Padding="12,6"/>
                </StackPanel>

                <!-- ── Works body: grid col 0 | splitter col 1 | inline viewer col 2 ── -->
                <Grid x:Name="WorksBodyGrid" IsVisible="{Binding HasRecommendedWorks}"
                      PointerMoved="OnSplitterPointerMoved"
                      PointerReleased="OnSplitterPointerReleased">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto" MinWidth="0"/>
                    </Grid.ColumnDefinitions>


                    <!-- Splitter -->
                    <Border Grid.Column="1" Width="5" Name="DiscoverSplitter"
                            Cursor="SizeWestEast"
                            Background="{actipro:ThemeResource Container1BorderBrush}"
                            IsVisible="{Binding ShowPreview}"
                            PointerPressed="OnSplitterPointerPressed"/>

                    <!-- Inline viewer side panel -->
                    <Border Grid.Column="2"
                            Width="{Binding BrowsePanelWidth}"
                            MinWidth="320"
                            Background="{actipro:ThemeResource Container1BackgroundBrush}"
                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                            BorderThickness="1,0,0,0"
                            IsVisible="{Binding ShowPreview}">
                        <local:InlineArtworkViewer x:Name="DiscoverSidePanelViewer" 
                                                   DataContext="{Binding GalleryVm}"
                                                   IsExpanded="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).IsViewerExpanded}"/>
                    </Border>

                    <!-- ── Grid view ── -->
                    <ScrollViewer Grid.Column="0" x:Name="WorksScrollViewer"
                                  Tapped="OnScrollViewerTapped"
                                  DoubleTapped="OnScrollViewerDoubleTapped"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  AllowAutoHide="False"
                                  IsVisible="{Binding IsGridView}"
                                  ScrollChanged="OnWorksScrollChanged">
                        <StackPanel>
                            <!-- Fixed height grid -->
                            <ItemsControl ItemsSource="{Binding FilteredWorks}" Margin="10,10,4,10"
                                          IsVisible="{Binding IsFixedHeight}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ArtworkCardViewModel">
                                        <Border Width="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).CardSize}"
                                                Margin="0,0,6,6"
                                                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                BoxShadow="0 1 4 0 #28000000" Cursor="Hand"
                                                PointerPressed="OnArtworkCardPressed"
                                                ContextMenu="{StaticResource ArtworkCardContextMenu}">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="BoxShadow" Value="0 6 20 0 #55000000"/>
                                                </Style>
                                            </Border.Styles>
                                            <Grid RowDefinitions="*,Auto">
                                                <Border Grid.Row="0"
                                                        Height="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).FixedCardTotalHeight}"
                                                        CornerRadius="7,7,0,0" ClipToBounds="True">
                                                    <Panel>
                                                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill">
                                                            <Image.Effect>
                                                                <BlurEffect Radius="{Binding IsBlurred, Converter={StaticResource BoolToBlurRadiusConverter}}"/>
                                                            </Image.Effect>
                                                        </Image>
                                                    </Panel>
                                                </Border>
                                                <Panel Grid.Row="0" ZIndex="5">
                                                    <!-- Selection checkbox -->
                                                    <CheckBox VerticalAlignment="Top" HorizontalAlignment="Left"
                                                              Margin="6,6,0,0"
                                                              IsChecked="{Binding IsSelected}"
                                                              Click="OnCardCheckboxClicked"/>
                                                    <!-- Page count badge -->
                                                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                            Margin="6,0,0,6" Padding="5,2" CornerRadius="4"
                                                            Background="#BB000000" IsVisible="{Binding IsMultiPage}"
                                                            IsHitTestVisible="False">
                                                        <TextBlock Text="{Binding PageCount, StringFormat='1/{0}'}" FontSize="9" Foreground="White"/>
                                                    </Border>
                                                    <!-- R-18 badge -->
                                                    <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                            Margin="0,6,6,0" Padding="5,2" CornerRadius="4"
                                                            Background="#CCDC2626" IsVisible="{Binding IsR18}"
                                                            IsHitTestVisible="False">
                                                        <TextBlock Text="R-18" FontSize="8" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                </Panel>
                                                <StackPanel Grid.Row="1" Spacing="2" Margin="8,5,8,7"
                                                            IsVisible="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).ShowInfo}">
                                                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <TextBlock Text="{Binding UserName}" FontSize="10"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <ItemsControl ItemsSource="{Binding TopTags}" Margin="0,1,0,0"
                                                                  IsVisible="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).ShowTags}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="x:String">
                                                                <Border Margin="0,1,3,1" Padding="5,2" CornerRadius="3"
                                                                        Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                        BorderThickness="0" Cursor="Hand"
                                                                        PointerPressed="OnTagChipPressed">
                                                                    <Border.Styles>
                                                                        <Style Selector="Border:pointerover">
                                                                            <Setter Property="Background" Value="Transparent"/>
                                                                        </Style>
                                                                        <Style Selector="Border:pointerover TextBlock">
                                                                            <Setter Property="TextDecorations" Value="Underline"/>
                                                                            <Setter Property="Foreground" Value="#5B8DEF"/>
                                                                        </Style>
                                                                    </Border.Styles>
                                                                    <TextBlock Text="{Binding}" FontSize="10"
                                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Natural height masonry grid -->
                            <ItemsControl ItemsSource="{Binding FilteredWorks}" Margin="10,10,4,10"
                                          IsVisible="{Binding IsNaturalHeight}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <local:MasonryPanel ColumnWidth="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).CardSize}"
                                                            ItemSpacing="6"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ArtworkCardViewModel">
                                        <Border Margin="0,0,6,6"
                                                Width="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).CardSize}"
                                                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                BorderThickness="1" CornerRadius="8"
                                                BoxShadow="0 1 4 0 #28000000" Cursor="Hand"
                                                PointerPressed="OnArtworkCardPressed"
                                                ContextMenu="{StaticResource ArtworkCardContextMenu}">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="BoxShadow" Value="0 6 20 0 #55000000"/>
                                                </Style>
                                            </Border.Styles>
                                            <Grid RowDefinitions="*,Auto">
                                                <Border Grid.Row="0" CornerRadius="7,7,0,0" ClipToBounds="True">
                                                    <Panel>
                                                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill">
                                                            <Image.Height>
                                                                <MultiBinding Converter="{x:Static conv:MultiplyByAspectRatioConverter.Instance}">
                                                                    <Binding Path="$parent[UserControl].((vm:DiscoverViewModel)DataContext).CardSize"/>
                                                                    <Binding Path="ClampedAspectRatio"/>
                                                                </MultiBinding>
                                                            </Image.Height>
                                                            <Image.Effect>
                                                                <BlurEffect Radius="{Binding IsBlurred, Converter={StaticResource BoolToBlurRadiusConverter}}"/>
                                                            </Image.Effect>
                                                        </Image>
                                                    </Panel>
                                                </Border>
                                                <Panel Grid.Row="0" ZIndex="5">
                                                    <Panel.Height>
                                                        <MultiBinding Converter="{x:Static conv:MultiplyByAspectRatioConverter.Instance}">
                                                            <Binding Path="$parent[UserControl].((vm:DiscoverViewModel)DataContext).CardSize"/>
                                                            <Binding Path="ClampedAspectRatio"/>
                                                        </MultiBinding>
                                                    </Panel.Height>
                                                    <!-- Selection checkbox -->
                                                    <CheckBox VerticalAlignment="Top" HorizontalAlignment="Left"
                                                              Margin="6,6,0,0"
                                                              IsChecked="{Binding IsSelected}"
                                                              Click="OnCardCheckboxClicked"/>
                                                    <!-- Page count badge -->
                                                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                            Margin="6,0,0,6" Padding="5,2" CornerRadius="4"
                                                            Background="#BB000000" IsVisible="{Binding IsMultiPage}"
                                                            IsHitTestVisible="False">
                                                        <TextBlock Text="{Binding PageCount, StringFormat='1/{0}'}" FontSize="9" Foreground="White"/>
                                                    </Border>
                                                    <!-- R-18 badge -->
                                                    <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                            Margin="0,6,6,0" Padding="5,2" CornerRadius="4"
                                                            Background="#CCDC2626" IsVisible="{Binding IsR18}"
                                                            IsHitTestVisible="False">
                                                        <TextBlock Text="R-18" FontSize="8" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                </Panel>
                                                <StackPanel Grid.Row="1" Spacing="2" Margin="8,5,8,7"
                                                            IsVisible="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).ShowInfo}">
                                                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <TextBlock Text="{Binding UserName}" FontSize="10"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <ItemsControl ItemsSource="{Binding TopTags}" Margin="0,1,0,0"
                                                                  IsVisible="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).ShowTags}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="x:String">
                                                                <Border Margin="0,1,3,1" Padding="5,2" CornerRadius="3"
                                                                        Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                        BorderThickness="0" Cursor="Hand"
                                                                        PointerPressed="OnTagChipPressed">
                                                                    <Border.Styles>
                                                                        <Style Selector="Border:pointerover">
                                                                            <Setter Property="Background" Value="Transparent"/>
                                                                        </Style>
                                                                        <Style Selector="Border:pointerover TextBlock">
                                                                            <Setter Property="TextDecorations" Value="Underline"/>
                                                                            <Setter Property="Foreground" Value="#5B8DEF"/>
                                                                        </Style>
                                                                    </Border.Styles>
                                                                    <TextBlock Text="{Binding}" FontSize="10"
                                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Load More button -->
                            <Button HorizontalAlignment="Center" Margin="0,4,0,12"
                                    CornerRadius="6" Padding="16,6" FontSize="12"
                                    Command="{Binding LoadMoreWorksCommand}"
                                    IsVisible="{Binding CanLoadMoreRecommended}"
                                    Content="Load More"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── List view ── -->
                    <ScrollViewer Grid.Column="0" x:Name="WorksListScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  AllowAutoHide="False"
                                  IsVisible="{Binding IsListView}"
                                  ScrollChanged="OnWorksScrollChanged"
                                  Tapped="OnScrollViewerTapped"
                                  DoubleTapped="OnScrollViewerDoubleTapped"
                                  Padding="10,10,10,4">
                        <ItemsControl ItemsSource="{Binding FilteredWorks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ArtworkCardViewModel">
                                    <Border Margin="0,0,0,3"
                                            Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Padding="6"
                                            Cursor="Hand"
                                            ContextMenu="{StaticResource ArtworkCardContextMenu}">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"/>
                                                <Setter Property="Background" Value="{actipro:ThemeResource Container2BackgroundBrush}"/>
                                            </Style>
                                        </Border.Styles>
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="4"
                                                    ClipToBounds="True" Margin="0,0,10,0"
                                                    Background="{actipro:ThemeResource Container2BackgroundBrush}">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding UserName}" FontSize="11"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                    <TextBlock Text="{Binding TypeLabel}" FontSize="11"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                    <TextBlock Text="{Binding PageCount, StringFormat='{}{0} pages'}"
                                                               FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                               IsVisible="{Binding IsMultiPage}"/>
                                                    <Border Background="#CCDC2626" CornerRadius="3" Padding="4,1" IsVisible="{Binding IsR18}">
                                                        <TextBlock Text="R-18" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Users Tab: two-column artist list + artist works ── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Grid IsVisible="{Binding IsUsersTab}">

                <!-- Loading -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsVisible="{Binding IsLoading}" Spacing="8" ZIndex="2">
                    <ProgressBar IsIndeterminate="True" Width="60"/>
                    <TextBlock Text="Loading…" FontSize="13" Opacity="0.7" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                            IsVisible="{Binding !HasRecommendedUsers}">
                    <TextBlock Text="No recommended users" FontSize="14" Opacity="0.6" HorizontalAlignment="Center"
                               IsVisible="{Binding !IsLoading}"/>
                    <Button Content="⟳ Retry" HorizontalAlignment="Center" CornerRadius="6" Padding="12,6"
                            Command="{Binding LoadRecommendedUsersCommand}"
                            IsVisible="{Binding !IsLoading}"/>
                </StackPanel>

                <!-- Two-column layout -->
                <Grid IsVisible="{Binding HasRecommendedUsers}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" MinWidth="200"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: artist list -->
                    <Border Grid.Column="0"
                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                            BorderThickness="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      AllowAutoHide="False">
                            <ItemsControl ItemsSource="{Binding RecommendedUsers}" Margin="8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:DiscoveryUserCardViewModel">
                                        <Border Margin="0,0,0,4" Padding="10,8" CornerRadius="8"
                                                Cursor="Hand"
                                                ContextMenu="{StaticResource UserCardContextMenu}"
                                                PointerPressed="OnUserCardClicked">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="Background" Value="{actipro:ThemeResource Container2BackgroundBrush}"/>
                                                </Style>
                                            </Border.Styles>
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                        ClipToBounds="True" Margin="0,0,10,0"
                                                        Background="{actipro:ThemeResource Container2BackgroundBrush}">
                                                    <Image Source="{Binding ProfileImage}" Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding UserName}" FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <TextBlock Text="{Binding UserId, StringFormat='ID {0}'}"
                                                               FontSize="10"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                               Cursor="IBeam"
                                                               ToolTip.Tip="Click to copy ID"
                                                               PointerPressed="OnUserIdPressed">
                                                        <TextBlock.Styles>
                                                            <Style Selector="TextBlock:pointerover">
                                                                <Setter Property="TextDecorations" Value="Underline"/>
                                                            </Style>
                                                        </TextBlock.Styles>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Grid.Column="2" FontSize="10" Padding="6,3"
                                                        CornerRadius="4" VerticalAlignment="Center"
                                                        ToolTip.Tip="Open in Gallery"
                                                        Click="OnUserOpenGalleryClicked">↗</Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Column splitter (visual only — artist panel is fixed 260px) -->
                    <Border Grid.Column="1"
                            Background="{actipro:ThemeResource Container1BorderBrush}"/>

                    <!-- Right: selected artist's works -->
                    <Grid Grid.Column="2" RowDefinitions="Auto,*">
                        <!-- Artist header bar -->
                        <Border Grid.Row="0"
                                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="12,6"
                                IsVisible="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Text="{Binding SelectedUser.UserName}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    
                                    <!-- Download buttons -->
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Content="↓ Download All" CornerRadius="6" Padding="10,6" FontSize="11"
                                                Classes="accent"
                                                Command="{Binding DownloadAllCommand}"
                                                IsEnabled="{Binding !IsBulkDownloading}"
                                                ToolTip.Tip="Download every artwork from this artist"/>
                                        <Button Content="↓ Download Loaded" CornerRadius="6" Padding="10,6" FontSize="11"
                                                Command="{Binding DownloadVisibleCommand}"
                                                IsEnabled="{Binding !IsBulkDownloading}"
                                                ToolTip.Tip="Download only the artworks currently shown"/>
                                        <Button CornerRadius="6" Padding="10,6" FontSize="11"
                                                Command="{Binding DownloadSelectedCommand}"
                                                IsEnabled="{Binding !IsBulkDownloading}"
                                                IsVisible="{Binding SelectedCount}"
                                                ToolTip.Tip="Download only the checked artworks">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="↓" FontSize="12"/>
                                                <TextBlock Text="{Binding SelectedCount, StringFormat='Download Selected ({0})'}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Content="🎨 Download Preset" CornerRadius="6" Padding="10,6" FontSize="11"
                                                Classes="accent"
                                                Click="OnDownloadPresetClicked"
                                                IsEnabled="{Binding !IsBulkDownloading}"
                                                ToolTip.Tip="Download with image processing preset"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" FontSize="11" Padding="8,4" CornerRadius="6"
                                        ToolTip.Tip="Open artist's full gallery"
                                        Click="OnOpenSelectedUserGalleryClicked">↗ Open Gallery</Button>
                            </Grid>
                        </Border>

                        <!-- Content area: grid | splitter | inline viewer (same as Works tab) -->
                        <Grid Grid.Row="1" x:Name="ArtistWorksBodyGrid"
                              PointerMoved="OnSplitterPointerMoved"
                              PointerReleased="OnSplitterPointerReleased">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto" MinWidth="0"/>
                            </Grid.ColumnDefinitions>


                            <!-- Splitter -->
                            <Border Grid.Column="1" Width="5"
                                    Cursor="SizeWestEast"
                                    Background="{actipro:ThemeResource Container1BorderBrush}"
                                    IsVisible="{Binding ShowPreview}"
                                    PointerPressed="OnSplitterPointerPressed"/>

                            <!-- Inline viewer side panel -->
                            <Border Grid.Column="2"
                                    Width="{Binding BrowsePanelWidth}"
                                    MinWidth="320"
                                    Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                    BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                    BorderThickness="1,0,0,0"
                                    IsVisible="{Binding ShowPreview}">
                                <local:InlineArtworkViewer x:Name="ArtistWorksSidePanelViewer"
                                                           DataContext="{Binding GalleryVm}"
                                                           IsExpanded="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).IsViewerExpanded}"/>
                            </Border>

                            <!-- Left: artist works scrollable grid -->
                            <Grid Grid.Column="0">
                                <!-- Loading spinner -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            IsVisible="{Binding IsLoadingArtistWorks}" Spacing="8">
                                    <ProgressBar IsIndeterminate="True" Width="60"/>
                                    <TextBlock Text="Loading works…" FontSize="13" Opacity="0.7" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- No artist selected yet -->
                                <TextBlock Text="Select an artist to view their works"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Opacity="0.5"
                                           IsVisible="{Binding ShowNoArtistPlaceholder}"/>

                                <!-- Artist selected but no works (e.g. R-18 filtered out) -->
                                <TextBlock Text="No works to show (check R-18 filter)"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Opacity="0.5"
                                           IsVisible="{Binding ShowNoWorksPlaceholder}"/>

                                <!-- Grid view (fixed + natural height) -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              AllowAutoHide="False"
                                              IsVisible="{Binding IsGridView}"
                                              Tapped="OnArtistWorksScrollViewerTapped"
                                              DoubleTapped="OnArtistWorksScrollViewerDoubleTapped">
                                    <StackPanel>
                                        <!-- Fixed height -->
                                        <ItemsControl ItemsSource="{Binding FilteredArtistWorks}" Margin="10,10,4,4"
                                                      IsVisible="{Binding IsFixedHeight}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ArtworkCardViewModel">
                                                    <Border Width="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).CardSize}"
                                                            Margin="0,0,6,6"
                                                            Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                            BorderThickness="1" CornerRadius="8"
                                                            BoxShadow="0 1 4 0 #28000000" Cursor="Hand"
                                                            ContextMenu="{StaticResource ArtworkCardContextMenu}">
                                                        <Border.Styles>
                                                            <Style Selector="Border:pointerover">
                                                                <Setter Property="BoxShadow" Value="0 6 20 0 #55000000"/>
                                                                <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"/>
                                                            </Style>
                                                        </Border.Styles>
                                                        <Grid RowDefinitions="*,Auto">
                                                            <Border Grid.Row="0"
                                                                    Height="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).FixedCardTotalHeight}"
                                                                    CornerRadius="7,7,0,0" ClipToBounds="True">
                                                                <Panel>
                                                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                            IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill">
                                                                        <Image.Effect>
                                                                            <BlurEffect Radius="{Binding IsBlurred, Converter={StaticResource BoolToBlurRadiusConverter}}"/>
                                                                        </Image.Effect>
                                                                    </Image>
                                                                </Panel>
                                                            </Border>
                                                            <Panel Grid.Row="0" ZIndex="5" IsHitTestVisible="False">
                                                                <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                                        Margin="6,0,0,6" Padding="5,2" CornerRadius="4"
                                                                        Background="#BB000000" IsVisible="{Binding IsMultiPage}">
                                                                    <TextBlock Text="{Binding PageCount, StringFormat='1/{0}'}" FontSize="9" Foreground="White"/>
                                                                </Border>
                                                                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                                        Margin="0,6,6,0" Padding="5,2" CornerRadius="4"
                                                                        Background="#CCDC2626" IsVisible="{Binding IsR18}">
                                                                    <TextBlock Text="R-18" FontSize="8" Foreground="White" FontWeight="Bold"/>
                                                                </Border>
                                                            </Panel>
                                                            <StackPanel Grid.Row="1" Spacing="2" Margin="8,5,8,7"
                                                                        IsVisible="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).ShowInfo}">
                                                                <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                                <TextBlock Text="{Binding UserName}" FontSize="10"
                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <ItemsControl ItemsSource="{Binding TopTags}" Margin="0,1,0,0"
                                                                              IsVisible="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).ShowTags}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="x:String">
                                                                            <Border Margin="0,1,3,1" Padding="5,2" CornerRadius="3"
                                                                                    Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                                    BorderThickness="0" Cursor="Hand"
                                                                                    PointerPressed="OnTagChipPressed">
                                                                                <Border.Styles>
                                                                                    <Style Selector="Border:pointerover TextBlock">
                                                                                        <Setter Property="TextDecorations" Value="Underline"/>
                                                                                        <Setter Property="Foreground" Value="#5B8DEF"/>
                                                                                    </Style>
                                                                                </Border.Styles>
                                                                                <TextBlock Text="{Binding}" FontSize="10"
                                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Natural height masonry -->
                                        <ItemsControl ItemsSource="{Binding FilteredArtistWorks}" Margin="10,10,4,4"
                                                      IsVisible="{Binding IsNaturalHeight}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <local:MasonryPanel ColumnWidth="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).CardSize}"
                                                                        ItemSpacing="6"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ArtworkCardViewModel">
                                                    <Border Margin="0,0,6,6"
                                                            Width="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).CardSize}"
                                                            Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                            BorderThickness="1" CornerRadius="8"
                                                            BoxShadow="0 1 4 0 #28000000" Cursor="Hand"
                                                            ContextMenu="{StaticResource ArtworkCardContextMenu}">
                                                        <Border.Styles>
                                                            <Style Selector="Border:pointerover">
                                                                <Setter Property="BoxShadow" Value="0 6 20 0 #55000000"/>
                                                                <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"/>
                                                            </Style>
                                                        </Border.Styles>
                                                        <Grid RowDefinitions="*,Auto">
                                                            <Border Grid.Row="0" CornerRadius="7,7,0,0" ClipToBounds="True">
                                                                <Panel>
                                                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                            IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill">
                                                                        <Image.Height>
                                                                            <MultiBinding Converter="{x:Static conv:MultiplyByAspectRatioConverter.Instance}">
                                                                                <Binding Path="$parent[UserControl].((vm:DiscoverViewModel)DataContext).CardSize"/>
                                                                                <Binding Path="AspectRatio"/>
                                                                            </MultiBinding>
                                                                        </Image.Height>
                                                                        <Image.Effect>
                                                                            <BlurEffect Radius="{Binding IsBlurred, Converter={StaticResource BoolToBlurRadiusConverter}}"/>
                                                                        </Image.Effect>
                                                                    </Image>
                                                                </Panel>
                                                            </Border>
                                                            <Panel Grid.Row="0" ZIndex="5" IsHitTestVisible="False">
                                                                <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                                        Margin="6,0,0,6" Padding="5,2" CornerRadius="4"
                                                                        Background="#BB000000" IsVisible="{Binding IsMultiPage}">
                                                                    <TextBlock Text="{Binding PageCount, StringFormat='1/{0}'}" FontSize="9" Foreground="White"/>
                                                                </Border>
                                                                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                                        Margin="0,6,6,0" Padding="5,2" CornerRadius="4"
                                                                        Background="#CCDC2626" IsVisible="{Binding IsR18}">
                                                                    <TextBlock Text="R-18" FontSize="8" Foreground="White" FontWeight="Bold"/>
                                                                </Border>
                                                            </Panel>
                                                            <StackPanel Grid.Row="1" Spacing="2" Margin="8,5,8,7"
                                                                        IsVisible="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).ShowInfo}">
                                                                <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                                <TextBlock Text="{Binding UserName}" FontSize="10"
                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <ItemsControl ItemsSource="{Binding TopTags}" Margin="0,1,0,0"
                                                                              IsVisible="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).ShowTags}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="x:String">
                                                                            <Border Margin="0,1,3,1" Padding="5,2" CornerRadius="3"
                                                                                    Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                                    BorderThickness="0" Cursor="Hand"
                                                                                    PointerPressed="OnTagChipPressed">
                                                                                <Border.Styles>
                                                                                    <Style Selector="Border:pointerover TextBlock">
                                                                                        <Setter Property="TextDecorations" Value="Underline"/>
                                                                                        <Setter Property="Foreground" Value="#5B8DEF"/>
                                                                                    </Style>
                                                                                </Border.Styles>
                                                                                <TextBlock Text="{Binding}" FontSize="10"
                                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- List view -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              AllowAutoHide="False"
                                              IsVisible="{Binding IsListView}"
                                              Tapped="OnArtistWorksScrollViewerTapped"
                                              DoubleTapped="OnArtistWorksScrollViewerDoubleTapped">
                                    <ItemsControl ItemsSource="{Binding FilteredArtistWorks}" Margin="8,8,4,8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ArtworkCardViewModel">
                                                <Border Margin="0,0,0,4" Padding="8" CornerRadius="6"
                                                        Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                        BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                        BorderThickness="1" Cursor="Hand"
                                                        ContextMenu="{StaticResource ArtworkCardContextMenu}">
                                                    <Border.Styles>
                                                        <Style Selector="Border:pointerover">
                                                            <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"/>
                                                        </Style>
                                                    </Border.Styles>
                                                    <Grid ColumnDefinitions="Auto,*">
                                                        <Border Grid.Column="0" Width="60" Height="60"
                                                                CornerRadius="4" ClipToBounds="True" Margin="0,0,10,0">
                                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill">
                                                                <Image.Effect>
                                                                    <BlurEffect Radius="{Binding IsBlurred, Converter={StaticResource BoolToBlurRadiusConverter}}"/>
                                                                </Image.Effect>
                                                            </Image>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                            <TextBlock Text="{Binding UserName}" FontSize="10"
                                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid><!-- end content Grid Row=1 -->
                    </Grid><!-- end right panel Grid -->
                </Grid><!-- end two-column Grid -->
            </Grid><!-- end Users tab Grid -->
        </Grid><!-- end content area -->

        <!-- Full-screen viewer overlay — covers entire view incl. toolbar -->
        <local:InlineArtworkViewer x:Name="DiscoverInlineViewer"
                                    Grid.Row="0" Grid.RowSpan="3"
                                    Margin="0,32,0,0"
                                    IsVisible="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).IsViewerExpanded}"
                                    IsExpanded="{Binding $parent[UserControl].((vm:DiscoverViewModel)DataContext).IsViewerExpanded}"
                                    ZIndex="10"
                                    DataContext="{Binding GalleryVm}"/>

        <!-- ── Status bar ── -->
        <Border Grid.Row="2"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,1,0,0" Padding="14,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" FontSize="11"
                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                           Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="60" Height="3"
                             IsVisible="{Binding IsLoading}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
