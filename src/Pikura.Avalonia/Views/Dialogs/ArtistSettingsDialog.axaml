<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        x:Class="Pikura.Avalonia.Views.Dialogs.ArtistSettingsDialog"
        Title="Artist Download Settings"
        Width="620"
        Height="620"
        MinWidth="520"
        MinHeight="480"
        MaxHeight="740"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock x:Name="TitleTextBlock" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="Leave fields blank to inherit global defaults."
                               FontSize="11"
                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                </StackPanel>
                <CheckBox x:Name="UseGlobalSettingsCheckBox"
                          Grid.Column="1"
                          Content="Use global defaults"
                          FontSize="11"
                          VerticalAlignment="Center"
                          Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- Action bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Content="Reset to defaults"
                        Click="ResetButton_Click"
                        CornerRadius="6" Padding="10,7" FontSize="12"
                        ToolTip.Tip="Clear all per-artist overrides"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="CancelBtn" Content="Cancel"
                            Click="CancelButton_Click"
                            CornerRadius="6" Padding="12,7"/>
                    <Button Content="Save"
                            Click="SaveButton_Click"
                            Classes="accent"
                            CornerRadius="6" Padding="14,7"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body: no ScrollViewer needed — content fits in window -->
        <StackPanel x:Name="SettingsPanel" Spacing="8" Margin="16,10,16,10">

            <!-- Row 1: Location + Naming side by side -->
            <Grid ColumnDefinitions="*,8,*">

                <!-- Location -->
                <Border Grid.Column="0"
                        Background="{actipro:ThemeResource Container2BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="📁 Location" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="Download folder"
                                   FontSize="10"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0"
                                     x:Name="DownloadRootTextBox"
                                     PlaceholderText="Global folder"
                                     FontSize="11"
                                     CornerRadius="5"/>
                            <Button Grid.Column="1"
                                    Content="…"
                                    Click="BrowseFolderButton_Click"
                                    CornerRadius="5" Padding="10,5" FontSize="12"
                                    ToolTip.Tip="Browse for folder"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Naming -->
                <Border Grid.Column="2"
                        Background="{actipro:ThemeResource Container2BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="✏ Naming" FontWeight="SemiBold" FontSize="12"/>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Folder template"
                                       FontSize="10"
                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                            <TextBox x:Name="FolderTemplateTextBox"
                                     PlaceholderText="%artist% (%member_id%)"
                                     FontSize="11" CornerRadius="5"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Filename template"
                                       FontSize="10"
                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                            <TextBox x:Name="FilenameTemplateTextBox"
                                     PlaceholderText="%image_id% - %title%"
                                     FontSize="11" CornerRadius="5"/>
                        </StackPanel>
                        <TextBlock Text="%artist% %member_id% %image_id% %title% %page_index% %tags% %date%"
                                   FontSize="9"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 2: Filtering -->
            <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                    BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid ColumnDefinitions="*,12,*,12,Auto">

                    <!-- Include tags -->
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="🔍 Include tags" FontWeight="SemiBold" FontSize="12"/>
                        <TextBox x:Name="IncludeTagsTextBox"
                                 PlaceholderText="e.g. landscape, scenery"
                                 FontSize="11" CornerRadius="5"/>
                        <TextBlock Text="Only download artworks with these tags"
                                   FontSize="10"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Exclude tags -->
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="🚫 Exclude tags" FontWeight="SemiBold" FontSize="12"/>
                        <TextBox x:Name="ExcludeTagsTextBox"
                                 PlaceholderText="e.g. R-18G, sketch"
                                 FontSize="11" CornerRadius="5"/>
                        <TextBlock Text="Skip artworks that have these tags"
                                   FontSize="10"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Date range + options -->
                    <StackPanel Grid.Column="4" Spacing="8" Width="140">
                        <TextBlock Text="📅 Date range" FontWeight="SemiBold" FontSize="12"/>
                        <StackPanel Spacing="4">
                            <TextBlock Text="From (YYYY-MM-DD)"
                                       FontSize="10"
                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                            <TextBox x:Name="DateFromTextBox"
                                     PlaceholderText="e.g. 2023-01-01"
                                     FontSize="11" CornerRadius="5"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="To (YYYY-MM-DD)"
                                       FontSize="10"
                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                            <TextBox x:Name="DateToTextBox"
                                     PlaceholderText="e.g. 2024-12-31"
                                     FontSize="11" CornerRadius="5"/>
                        </StackPanel>
                        <Button Content="Clear dates"
                                Click="ClearDatesButton_Click"
                                HorizontalAlignment="Stretch"
                                CornerRadius="4" Padding="6,4" FontSize="11"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- Row 3: Behavior + AI (combined) -->
            <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                    BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,10">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="⚙ Download Behavior"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <CheckBox x:Name="CreateSubfolderCheckBox"
                              Grid.Column="1"
                              Content="Subfolder per submission"
                              FontSize="11"
                              VerticalAlignment="Center"/>
                    <CheckBox x:Name="SeparateR18CheckBox"
                              Grid.Column="2"
                              Content="Separate R-18 folder"
                              FontSize="11"
                              VerticalAlignment="Center"
                              Margin="12,0"/>
                    <Border Grid.Column="3" Width="1"
                            Background="{actipro:ThemeResource Container2BorderBrush}"
                            Margin="8,2" VerticalAlignment="Stretch"/>
                    <CheckBox x:Name="FilterAiCheckBox"
                              Grid.Column="4"
                              Content="Skip AI-generated artworks"
                              FontSize="11"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"/>
                    <CheckBox x:Name="AllowRedownloadCheckBox"
                              Grid.Column="5"
                              Content="Allow re-download"
                              FontSize="11"
                              VerticalAlignment="Center"
                              Margin="12,0,0,0"/>
                </Grid>
            </Border>

        </StackPanel>

    </DockPanel>
</Window>
