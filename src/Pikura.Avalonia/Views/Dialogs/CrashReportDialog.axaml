<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        x:Class="Pikura.Avalonia.Views.Dialogs.CrashReportDialog"
        Title="Pikura - Crash Detected"
        Width="640"
        Height="400"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        MinWidth="400"
        MinHeight="350">

    <Border Background="{actipro:ThemeResource Container1BackgroundBrush}"
            Padding="24">
        <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="Auto,*">
            <!-- Header with Icon -->
            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <!-- Warning Icon -->
                    <Border Width="48"
                            Height="48"
                            CornerRadius="24"
                            Background="#FFF44336">
                        <TextBlock Text="&#x26A0;"
                                   FontSize="28"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Pikura Crashed"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <TextBlock Text="We detected a crash from your previous session."
                                   FontSize="13"
                                   Opacity="0.7"/>
                    </StackPanel>
                </StackPanel>

                <Separator/>
            </StackPanel>

            <!-- Crash Details -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="16">
                <!-- Crash Info Card -->
                <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="Time:"
                                       FontWeight="SemiBold"
                                       Width="80"/>
                            <TextBlock x:Name="CrashTimeText"
                                       Grid.Column="1"
                                       Text="Unknown"/>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="Error:"
                                       FontWeight="SemiBold"
                                       Width="80"/>
                            <TextBlock x:Name="CrashTypeText"
                                       Grid.Column="1"
                                       Text="Unknown"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="Message:"
                                       FontWeight="SemiBold"
                                       Width="80"/>
                            <TextBlock x:Name="CrashMessageText"
                                       Grid.Column="1"
                                       Text="Unknown"
                                       TextWrapping="Wrap"
                                       MaxLines="2"
                                       Opacity="0.8"
                                       FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Log File Path -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Crash Log Location:"
                               FontWeight="SemiBold"
                               FontSize="12"/>
                    <TextBox x:Name="LogPathTextBox"
                             IsReadOnly="True"
                             FontSize="11"
                             FontFamily="Consolas,Monospace"/>
                </StackPanel>

                <!-- Explanation -->
                <TextBlock Text="A detailed crash report has been saved. You can use this to report the issue or troubleshoot the problem."
                           TextWrapping="Wrap"
                           FontSize="12"
                           Opacity="0.7"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12"
                        Margin="0,16,0,0">
                <Button x:Name="ViewLogButton"
                        Content="View Log File"
                        Click="OnViewLogClick"/>
                <Button x:Name="OpenFolderButton"
                        Content="Open Log Folder"
                        Click="OnOpenFolderClick"/>
                <Button x:Name="CopyPathButton"
                        Content="Copy Path"
                        Click="OnCopyPathClick"/>
                <Button x:Name="CopyContentsButton"
                        Content="Copy Contents"
                        Click="OnCopyContentsClick"/>
                <Button x:Name="DismissButton"
                        Content="Dismiss"
                        Classes="accent"
                        Click="OnDismissClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
