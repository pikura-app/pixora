<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Pikura.Avalonia.ViewModels"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        xmlns:conv="using:Pikura.Avalonia.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="Pikura.Avalonia.Views.Dialogs.ArtistSelectionDialog"
        x:DataType="vm:ArtistSelectionViewModel"
        Title="Select Artists"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:ArtistSelectionViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,12">
            <StackPanel Spacing="8">
                <TextBlock Text="Select Artists to Download" FontSize="16" FontWeight="SemiBold"/>
                <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                         PlaceholderText="Search artists..."
                         CornerRadius="6"/>
            </StackPanel>
        </Border>

        <!-- Artist List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Artists}" Margin="8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:SelectableArtist">
                        <Border IsVisible="{Binding IsVisible}"
                                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Opacity="{Binding IsAlreadyAdded, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="12,10">
                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="40" Height="40"
                                        CornerRadius="20"
                                        Background="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}">
                                    <TextBlock Text="👤" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding User.UserName}"
                                               FontSize="14" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding User.UserId, StringFormat='ID: {0}'}"
                                               FontSize="11"
                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                </StackPanel>

                                <!-- Checkbox -->
                                <CheckBox Grid.Column="2"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          IsEnabled="{Binding !IsAlreadyAdded}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{actipro:ThemeResource Container2BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center">
                    <Run Text="Selected: "/><Run Text="{Binding SelectedUsers.Count}" FontWeight="SemiBold"/>
                </TextBlock>
                <Button Grid.Column="1" Content="Cancel" Click="CancelButton_Click"
                        CornerRadius="6" Padding="16,8" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Add Selected" Click="OkButton_Click"
                        Classes="accent" CornerRadius="6" Padding="16,8"/>
            </Grid>
        </Border>
    </Grid>
</Window>
