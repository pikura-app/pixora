<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        x:Class="Pikura.Avalonia.Views.Login.ManualCookieDialog"
        Title="Paste PHPSESSID"
        Width="520" Height="270"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{actipro:ThemeResource Container2BackgroundBrush}">

    <StackPanel Margin="24,20" Spacing="14">

        <TextBlock Text="Manual sign-in (emergency fallback)" FontWeight="SemiBold" FontSize="14"/>

        <TextBlock x:Name="ReasonText" TextWrapping="Wrap" FontSize="11"
                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                   IsVisible="False"/>

        <TextBlock TextWrapping="Wrap" FontSize="12"
                   Foreground="{actipro:ThemeResource DefaultForegroundBrushSecondary}">
            Pikura couldn't open a sign-in window automatically, so paste your
            session cookie as a one-time workaround:
            open pixiv.net in your regular browser → DevTools → Application → Cookies →
            <Run FontWeight="SemiBold">www.pixiv.net</Run> → copy the value of
            <Run FontWeight="SemiBold">PHPSESSID</Run> and paste it below.
        </TextBlock>

        <TextBox x:Name="CookieInput"
                 PlaceholderText="Paste PHPSESSID value here…"
                 CornerRadius="6" FontSize="13"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" CornerRadius="6" Padding="14,7"
                    Click="OnCancel"/>
            <Button Content="Confirm" Classes="accent" CornerRadius="6" Padding="14,7"
                    Click="OnConfirm"/>
        </StackPanel>

    </StackPanel>
</Window>
