<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        x:Class="Pikura.Avalonia.Views.Login.ChromiumInstallDialog"
        Title="Setting up sign-in"
        Width="520" Height="240"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{actipro:ThemeResource Container2BackgroundBrush}">

    <Grid Margin="24,20" RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="12">

        <TextBlock Grid.Row="0" Text="Setting up sign-in"
                   FontWeight="SemiBold" FontSize="14"/>

        <TextBlock Grid.Row="1" x:Name="StatusText"
                   Text="Downloading the bundled browser used to sign you in. This happens once and takes a few minutes (~150 MB)."
                   TextWrapping="Wrap" FontSize="12"
                   Foreground="{actipro:ThemeResource DefaultForegroundBrushSecondary}"/>

        <ProgressBar Grid.Row="2" x:Name="Progress"
                     IsIndeterminate="True" Height="6"
                     CornerRadius="3"/>

        <TextBlock Grid.Row="3" x:Name="DetailText"
                   Text="Contacting playwright.dev…"
                   FontSize="11" VerticalAlignment="Top"
                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="CancelBtn" Content="Cancel"
                    CornerRadius="6" Padding="14,7"
                    Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
