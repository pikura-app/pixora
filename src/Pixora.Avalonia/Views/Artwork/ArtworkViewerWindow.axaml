<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        xmlns:vm="using:Pixora.Avalonia.ViewModels"
        x:Class="Pixora.Avalonia.Views.Artwork.ArtworkViewerWindow"
        x:DataType="vm:ArtworkViewerViewModel"
        Title="{Binding Title, StringFormat='Pixora — {0}'}"
        Width="1000" Height="750"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{actipro:ThemeResource Container3BackgroundBrush}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Zoom toolbar -->
        <Border Grid.Row="0"
                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,5">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Name="PopupZoomOutBtn" Content="−" Padding="10,4" CornerRadius="4" FontSize="14"
                        ToolTip.Tip="Zoom out"/>
                <Button Name="PopupZoomFitBtn" Content="Fit" Padding="10,4" CornerRadius="4" FontSize="12"
                        ToolTip.Tip="Reset zoom"/>
                <Button Name="PopupZoomInBtn"  Content="+" Padding="10,4" CornerRadius="4" FontSize="14"
                        ToolTip.Tip="Zoom in"/>
                <TextBlock Name="PopupZoomLabel" Text="100%" VerticalAlignment="Center"
                           Margin="8,0" FontSize="11"
                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                <TextBlock Text="|" VerticalAlignment="Center" Margin="4,0"
                           Foreground="{actipro:ThemeResource Container1BorderBrush}"/>
                <TextBlock Name="PopupResLabel" VerticalAlignment="Center" FontSize="11"
                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
            </StackPanel>
        </Border>

        <!-- Image area with page navigation -->
        <Grid Grid.Row="1">
            <!-- Zoomable canvas: the Canvas is the clip region; Image sits inside and is repositioned by transforms -->
            <Canvas Name="PopupCanvas" ClipToBounds="True"
                    Background="{actipro:ThemeResource Container3BackgroundBrush}">
                <Image Name="PopupImage"
                       Source="{Binding CurrentPageBitmap}"
                       Stretch="Uniform"
                       RenderTransformOrigin="0,0"
                       RenderOptions.BitmapInterpolationMode="HighQuality"/>                
            </Canvas>

            <!-- Loading spinner -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10"
                        IsVisible="{Binding IsLoadingPage}">
                <ProgressBar IsIndeterminate="True" Width="160"/>
                <TextBlock Text="Loading…" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Page navigation arrows -->
            <Button HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0"
                    Command="{Binding PrevPageCommand}"
                    IsVisible="{Binding HasMultiplePages}"
                    Content="‹" FontSize="28" Padding="10,4"
                    CornerRadius="20" Opacity="0.8"/>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0"
                    Command="{Binding NextPageCommand}"
                    IsVisible="{Binding HasMultiplePages}"
                    Content="›" FontSize="28" Padding="10,4"
                    CornerRadius="20" Opacity="0.8"/>

            <!-- Page indicator -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12"
                    Background="#CC000000" CornerRadius="10" Padding="12,4"
                    IsVisible="{Binding HasMultiplePages}">
                <TextBlock Text="{Binding PageIndicator}" Foreground="White" FontSize="12"/>
            </Border>
        </Grid>

        <!-- Bottom panel: info + actions -->
        <Border Grid.Row="2"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16,12">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Info -->
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding ArtistName}" FontSize="12" Foreground="#9CA3AF"/>
                        <TextBlock Text="{Binding TypeLabel}" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding PageCount, StringFormat='{}{0} pages'}"
                                   FontSize="12" Foreground="#6B7280"
                                   IsVisible="{Binding HasMultiplePages}"/>
                        <Border Background="#CC374151" CornerRadius="4" Padding="5,1"
                                IsVisible="{Binding IsR18}">
                            <TextBlock Text="R-18" FontSize="10" Foreground="#FC8181" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding TagsText}" FontSize="11" Foreground="#4B5563"
                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                </StackPanel>

                <!-- Download actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="↓ This page" CornerRadius="6" Padding="10,6" FontSize="12"
                            Command="{Binding DownloadCurrentPageCommand}"
                            IsEnabled="{Binding !IsDownloading}"/>
                    <Button Content="↓ All pages" CornerRadius="6" Padding="10,6" FontSize="12"
                            Command="{Binding DownloadAllPagesCommand}"
                            Classes="accent"
                            IsEnabled="{Binding !IsDownloading}"/>
                    <Button Content="↓ Range…" CornerRadius="6" Padding="10,6" FontSize="12"
                            Command="{Binding DownloadRangeCommand}"
                            IsEnabled="{Binding !IsDownloading}"
                            IsVisible="{Binding HasMultiplePages}"/>
                    <Button Content="✕ Close" CornerRadius="6" Padding="10,6" FontSize="12"
                            Command="{Binding CloseCommand}"/>
                    <ProgressBar IsIndeterminate="True" Width="60" Height="4"
                                 IsVisible="{Binding IsDownloading}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
