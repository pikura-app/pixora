<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
             xmlns:vm="using:Pixora.Avalonia.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Pixora.Avalonia.Views.History.HistoryView"
             x:DataType="vm:HistoryViewModel">

    <Design.DataContext>
        <vm:HistoryViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10"
                Margin="0,32,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="📜 History" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="View completed and archived downloads"
                               FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="🔄 Refresh"
                            Command="{Binding RefreshCommand}"
                            CornerRadius="6" Padding="12,8"/>
                    <Button Content="🔄 Retry All Failed"
                            Command="{Binding RetryAllFailedCommand}"
                            CornerRadius="6" Padding="12,8" Classes="accent"/>
                    <Button Content="� Clear Completed"
                            Command="{Binding ClearCompletedCommand}"
                            CornerRadius="6" Padding="12,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Jobs List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="16">
                <!-- Active Jobs Section -->
                <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="⏳ Active Downloads" FontSize="15" FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding ActiveJobs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:DownloadJobViewModel">
                                    <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,8"
                                            ClipToBounds="True">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- Thumbnail -->
                                            <Border Grid.Column="0" Width="72" Height="72"
                                                    CornerRadius="5,0,0,5" ClipToBounds="True"
                                                    Background="{actipro:ThemeResource Container2BackgroundBrush}">
                                                <Panel>
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasThumbnail}"/>
                                                    <ProgressBar IsIndeterminate="True" Height="3"
                                                                 VerticalAlignment="Bottom"
                                                                 IsVisible="{Binding !HasThumbnail}"/>
                                                </Panel>
                                            </Border>
                                            <!-- Info -->
                                            <Grid Grid.Column="1" ColumnDefinitions="Auto,*" Margin="12,8,12,8">
                                                <!-- Live current-file thumbnail -->
                                                <Border Grid.Column="0" Width="56" Height="56"
                                                        CornerRadius="4" ClipToBounds="True" Margin="0,0,10,0"
                                                        Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                        IsVisible="{Binding HasCurrentFile}">
                                                    <Panel>
                                                        <Image Source="{Binding CurrentFileThumbnail}"
                                                               Stretch="UniformToFill"
                                                               IsVisible="{Binding CurrentFileThumbnail, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                        <ProgressBar IsIndeterminate="True" Height="3"
                                                                     VerticalAlignment="Bottom"
                                                                     IsVisible="{Binding CurrentFileThumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                    </Panel>
                                                </Border>
                                                <!-- Text stack -->
                                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Job.Name}" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <TextBlock Text="{Binding CurrentArtist}" FontSize="11"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                               IsVisible="{Binding CurrentArtist, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <!-- Current file: artwork ID + page -->
                                                    <TextBlock Text="{Binding CurrentFileLabel}" FontSize="11"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushSecondary}"
                                                               IsVisible="{Binding HasCurrentFile}"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <!-- Overall progress bar -->
                                                    <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                                                 Height="4" CornerRadius="2" Margin="0,2,0,0"/>
                                                    <!-- Per-file byte progress bar -->
                                                    <ProgressBar Value="{Binding CurrentFilePct}" Maximum="100"
                                                                 Height="3" CornerRadius="2"
                                                                 IsVisible="{Binding HasCurrentFile}"
                                                                 Opacity="0.6"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Status + count -->
                                            <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,12,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding StatusText}" FontSize="12" HorizontalAlignment="Right"/>
                                                <TextBlock FontSize="11" HorizontalAlignment="Right"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                           IsVisible="{Binding TotalCount}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} / {1}">
                                                            <Binding Path="CompletedCount"/>
                                                            <Binding Path="TotalCount"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No active downloads" FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                   IsVisible="{Binding !ActiveJobs.Count}"/>
                    </StackPanel>
                </Border>

                <!-- Completed Jobs Section -->
                <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container2BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="✅ Completed Downloads" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding CompletedJobs.Count, StringFormat='{}{0} jobs'}"
                                       FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" VerticalAlignment="Center"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding CompletedJobs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:DownloadJobViewModel">
                                    <Border Background="{actipro:ThemeResource Container3BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container3BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,8"
                                            ClipToBounds="True">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- Thumbnail -->
                                            <Border Grid.Column="0" Width="72" Height="72"
                                                    CornerRadius="5,0,0,5" ClipToBounds="True"
                                                    Background="{actipro:ThemeResource Container2BackgroundBrush}">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding HasThumbnail}"/>
                                            </Border>
                                            <!-- Info -->
                                            <StackPanel Grid.Column="1" Spacing="3" Margin="12,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Job.Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <TextBlock FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} • {1:MMM d, yyyy HH:mm}">
                                                            <Binding Path="TypeLabel"/>
                                                            <Binding Path="Job.CompletedAt"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="{Binding ArtistInfo}" FontSize="11"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                           IsVisible="{Binding HasArtistInfo}"
                                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <TextBlock Text="{Binding ResultSummary}"
                                                           FontSize="11"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                            </StackPanel>
                                            <!-- Actions -->
                                            <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="4" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}" FontSize="12" HorizontalAlignment="Right"/>
                                                <Button Content="📂 Open Folder"
                                                        Command="{Binding OpenFolderCommand}"
                                                        IsVisible="{Binding HasOutputFolder}"
                                                        CornerRadius="6" Padding="8,4" FontSize="11"/>
                                                <Button Content="🔄 Retry Failed"
                                                        Command="{Binding $parent[ItemsControl].DataContext.RetryJobCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding HasFailedItems}"
                                                        CornerRadius="6" Padding="8,4" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No completed downloads" FontSize="13" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                   IsVisible="{Binding !CompletedJobs.Count}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
