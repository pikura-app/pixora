<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
             xmlns:vm="using:Pixora.Avalonia.ViewModels"
             xmlns:local="using:Pixora.Avalonia.Views.Gallery"
             xmlns:conv="using:Pixora.Avalonia.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Pixora.Avalonia.Views.Gallery.GalleryView"
             x:DataType="vm:GalleryViewModel">


    <UserControl.Resources>
        <!-- Converter for R-18 blur effect -->
        <conv:BoolToBlurRadiusConverter x:Key="BoolToBlurRadiusConverter" />

        <!-- Inline context menus defined per-card for proper DataContext -->
    </UserControl.Resources>

    <!-- Root: top bar | optional filter bar | content | status bar -->
    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ── Top bar (matches WPF reference) ──────────────────────── -->
        <Border Grid.Row="0"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="16,10,16,10"
                Margin="0,32,0,0">
            <!-- 3-col: left=title+actions | center=search(stretch) | right=downloads+view+size -->
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- LEFT: hamburger + title + count + Refresh + Recent Works -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Followed Artists" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"
                               AutomationProperties.Name="Gallery Header"
                               AutomationProperties.HelpText="List of artists you follow on Pixiv"/>
                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                            CornerRadius="10" Padding="8,2" VerticalAlignment="Center"
                            ToolTip.Tip="Number of followed artists loaded">
                        <TextBlock FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}">
                            <TextBlock.Text><Binding Path="Artists.Count"/></TextBlock.Text>
                        </TextBlock>
                    </Border>
                    <ProgressBar IsIndeterminate="True" Width="60" Height="3"
                                 IsVisible="{Binding IsLoadingArtists}" VerticalAlignment="Center"/>
                    <Rectangle Width="1" Height="20" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>
                    <Button Content="⟳ Refresh" CornerRadius="6" Padding="12,8" FontSize="12"
                            Command="{Binding RefreshFollowedArtistsCommand}"
                            ToolTip.Tip="Refresh followed artists list from Pixiv (clears local cache)"
                            AutomationProperties.Name="Refresh Button"
                            AutomationProperties.HelpText="Refresh the list of followed artists from Pixiv server"
                            KeyboardNavigation.TabIndex="1"/>
                    <Button CornerRadius="6" Padding="12,8" FontSize="12"
                            Command="{Binding CopyAllArtistIdsCommand}"
                            ToolTip.Tip="Click individual artist IDs to queue them, then press this to copy all queued IDs at once"
                            AutomationProperties.Name="Copy All Button"
                            KeyboardNavigation.TabIndex="1">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="📋 Copy All" FontSize="12"/>
                            <TextBlock Text="{Binding QueuedArtistCount, StringFormat='({0})'}" FontSize="12"
                                       IsVisible="{Binding QueuedArtistCount, Converter={x:Static conv:GreaterThanZeroConverter.Instance}}"/>
                        </StackPanel>
                    </Button>
                    <Button CornerRadius="6" Padding="12,8" FontSize="12"
                            Command="{Binding LoadRecentWorksCommand}"
                            ToolTip.Tip="View recent works from all followed artists"
                            AutomationProperties.Name="Recent Works Button"
                            AutomationProperties.HelpText="View recent works from all followed artists"
                            KeyboardNavigation.TabIndex="2">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🖼" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="Recent Works" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- CENTER: search bar — stretches to fill available space -->
                <Border Grid.Column="1" Margin="12,0"
                        Background="{actipro:ThemeResource Container2BackgroundBrush}"
                        CornerRadius="6" Height="34" VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="11" Margin="10,0,4,0"
                                   VerticalAlignment="Center" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}">
                            <ToolTip.Tip>
                                <StackPanel Spacing="6" MaxWidth="300">
                                    <TextBlock Text="Pixiv Search" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" TextWrapping="Wrap">
                                        <Run Text="• "/><Run Text="sakura" FontWeight="SemiBold"/><Run Text=" — search artworks by tag"/><LineBreak/>
                                        <Run Text="• "/><Run Text="123456" FontWeight="SemiBold"/><Run Text=" — open artwork by ID"/><LineBreak/>
                                        <Run Text="• "/><Run Text="u:12345" FontWeight="SemiBold"/><Run Text=" — open artist by user ID"/><LineBreak/>
                                        <Run Text="• "/><Run Text="a:name" FontWeight="SemiBold"/><Run Text=" — search artist by name"/>
                                    </TextBlock>
                                    <TextBlock FontSize="10" Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}" TextWrapping="Wrap"
                                               Text="Press Enter to search. Tag results are fetched live from Pixiv."/>
                                </StackPanel>
                            </ToolTip.Tip>
                        </TextBlock>
                        <TextBox Grid.Column="1" Text="{Binding IdSearchQuery}"
                                 PlaceholderText="Search tag, artist, or ID…"
                                 CornerRadius="0,6,6,0" FontSize="11"
                                 Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 KeyDown="OnIdSearchKeyDown"/>
                    </Grid>
                </Border>

                <!-- RIGHT: downloads | grid/list+preview+filters | size slider -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">

                    <!-- Download buttons — only shown when an artist is selected -->
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                IsVisible="{Binding SelectedArtist, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Button Content="↓ Download All" CornerRadius="6" Padding="10,6" FontSize="11"
                                Classes="accent"
                                Command="{Binding DownloadAllCommand}"
                                IsEnabled="{Binding !IsBulkDownloading}"
                                ToolTip.Tip="Download every artwork from this artist to disk"/>
                        <Button Content="↓ Download Loaded" CornerRadius="6" Padding="10,6" FontSize="11"
                                Command="{Binding DownloadVisibleCommand}"
                                IsEnabled="{Binding !IsBulkDownloading}"
                                ToolTip.Tip="Download only the artworks currently shown in the grid"/>
                        <Button CornerRadius="6" Padding="10,6" FontSize="11"
                                Command="{Binding DownloadSelectedCommand}"
                                IsEnabled="{Binding !IsBulkDownloading}"
                                IsVisible="{Binding SelectedCount}"
                                ToolTip.Tip="Download only the checked artworks">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="↓" FontSize="12"/>
                                <TextBlock Text="{Binding SelectedCount, StringFormat='Download Selected ({0})'}" />
                            </StackPanel>
                        </Button>
                        <Button Content="↓ Download Range…" CornerRadius="6" Padding="10,6" FontSize="11"
                                Click="OnDownloadRangeClicked"
                                IsEnabled="{Binding !IsBulkDownloading}"
                                ToolTip.Tip="Choose a numbered range to download (e.g. 1-20)"/>
                        <Button Content="🎨 Download Preset" CornerRadius="6" Padding="10,6" FontSize="11"
                                Classes="accent"
                                Click="OnDownloadPresetClicked"
                                IsEnabled="{Binding !IsBulkDownloading}"
                                ToolTip.Tip="Download with image processing preset"/>
                    </StackPanel>

                    <Rectangle Width="1" Height="20" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"
                               IsVisible="{Binding SelectedArtist, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                    <!-- Preview + Filters -->
                    <ToggleButton IsChecked="{Binding ShowPreview}"
                                  CornerRadius="6" Padding="10,6" FontSize="11"
                                  ToolTip.Tip="Toggle the side panel (browse artworks alongside the viewer)">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="▣" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="Side Panel" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton IsChecked="{Binding ShowFilters}"
                                  CornerRadius="6" Padding="10,6" FontSize="11"
                                  ToolTip.Tip="Toggle tag and date filters">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="⧉" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="Filters" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Sort — standalone dropdown styled like other buttons -->
                    <ComboBox Name="SortCombo" SelectedIndex="0"
                              FontSize="11" CornerRadius="6"
                              Padding="10,6" MaxDropDownHeight="400"
                              SelectionChanged="OnSortComboChanged"
                              ToolTip.Tip="Sort artworks">
                        <ComboBoxItem Content="🗒 Default"/>
                        <ComboBoxItem Content="A → Z"/>
                        <ComboBoxItem Content="Z → A"/>
                        <ComboBoxItem Content="⬇ Newest first"/>
                        <ComboBoxItem Content="⬆ Oldest first"/>
                        <ComboBoxItem Content="📚 Most pages"/>
                    </ComboBox>

                    <Rectangle Width="1" Height="20" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>

                    <!-- Card size + height mode + Grid/List — far right -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                IsVisible="{Binding IsGridView}">
                        <ToggleButton IsChecked="{Binding IsFixedHeight}"
                                      Command="{Binding SetFixedHeightCommand}"
                                      CornerRadius="6" Padding="10,6" FontSize="11"
                                      ToolTip.Tip="Fixed card height">
                            <ToggleButton.Styles>
                                <Style Selector="ToggleButton:checked">
                                    <Setter Property="Background" Value="#3B82F6"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </ToggleButton.Styles>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="⬛" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="Fixed" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding IsNaturalHeight}"
                                      Command="{Binding SetNaturalHeightCommand}"
                                      CornerRadius="6" Padding="10,6" FontSize="11"
                                      ToolTip.Tip="Natural height (preserves aspect ratio)">
                            <ToggleButton.Styles>
                                <Style Selector="ToggleButton:checked">
                                    <Setter Property="Background" Value="#3B82F6"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </ToggleButton.Styles>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="↕" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="Natural" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <Rectangle Width="1" Height="20" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>
                        <ToggleButton IsChecked="{Binding ShowTags}"
                                      CornerRadius="6" Padding="10,6" FontSize="11"
                                      ToolTip.Tip="Show/hide tags on cards">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="🏷" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="Tags" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding ShowInfo}"
                                      CornerRadius="6" Padding="10,6" FontSize="11"
                                      ToolTip.Tip="Show/hide card info strip (title + tags)">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="ℹ" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="Info" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <Rectangle Width="1" Height="20" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>
                        <TextBlock Text="Size" FontSize="11"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                   VerticalAlignment="Center"/>
                        <Slider Value="{Binding CardSize}" Minimum="120" Maximum="300" Width="90"
                                VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- View mode — after slider, always visible -->
                    <Rectangle Width="1" Height="20" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>
                    <Button CornerRadius="6" Padding="10,6" FontSize="11"
                            Command="{Binding SetGridViewCommand}"
                            IsEnabled="{Binding !IsGridView}"
                            ToolTip.Tip="Grid view">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="⊞" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="Grid" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button CornerRadius="6" Padding="10,6" FontSize="11"
                            Command="{Binding SetListViewCommand}"
                            IsEnabled="{Binding !IsListView}"
                            ToolTip.Tip="List view">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="☰" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="List" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="2,0"/>
                    
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Collapsible filter bar (tag + date only, no sort) ────────── -->
        <Border Grid.Row="1"
                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="14,8">
            <Border.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="ShowFilters"/>
                    <Binding Path="!IsViewerFullScreen"/>
                </MultiBinding>
            </Border.IsVisible>
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

                <!-- Tag include -->
                <StackPanel Spacing="4">
                    <TextBlock Text="INCLUDE TAGS" FontSize="9" FontWeight="SemiBold"
                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                               LetterSpacing="1"/>
                    <TextBox Text="{Binding TagIncludeFilter}" Width="160"
                             PlaceholderText="tag1, tag2, …" CornerRadius="6" FontSize="11"
                             Padding="8,5"
                             ToolTip.Tip="Show only artworks that have ALL of these tags (comma-separated)"/>
                </StackPanel>

                <!-- Tag exclude -->
                <StackPanel Spacing="4">
                    <TextBlock Text="EXCLUDE TAGS" FontSize="9" FontWeight="SemiBold"
                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                               LetterSpacing="1"/>
                    <TextBox Text="{Binding TagExcludeFilter}" Width="160"
                             PlaceholderText="tag1, tag2, …" CornerRadius="6" FontSize="11"
                             Padding="8,5"
                             ToolTip.Tip="Hide artworks that have ANY of these tags (comma-separated)"/>
                </StackPanel>

                <Rectangle Width="1" Height="36" Fill="{actipro:ThemeResource Container1BorderBrush}" VerticalAlignment="Center"/>

                <!-- Date range -->
                <StackPanel Spacing="4">
                    <TextBlock Text="DATE RANGE" FontSize="9" FontWeight="SemiBold"
                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                               LetterSpacing="1"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <DatePicker SelectedDate="{Binding DateFrom}" FontSize="11"
                                    ToolTip.Tip="Show artworks from this date"/>
                        <TextBlock Text="→" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                        <DatePicker SelectedDate="{Binding DateTo}" FontSize="11"
                                    ToolTip.Tip="Show artworks up to this date"/>
                    </StackPanel>
                </StackPanel>

                <Rectangle Width="1" Height="36" Fill="{actipro:ThemeResource Container1BorderBrush}" VerticalAlignment="Center"/>

                <Button Content="✕ Clear filters" CornerRadius="6" Padding="10,6" FontSize="11"
                        Click="OnClearFilters" VerticalAlignment="Bottom"
                        ToolTip.Tip="Clear all tag and date filters"/>
            </StackPanel>
        </Border>

        <!-- ── Main body: sidebar | artwork grid | inline viewer ──────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="230,1,*" Name="BodyGrid"
              Background="{actipro:ThemeResource Container1BackgroundBrush}">
            <!-- Sidebar divider — hidden with sidebar -->
            <Rectangle Grid.Column="1"
                       Fill="{actipro:ThemeResource Container1BorderBrush}"
                       Width="1" HorizontalAlignment="Stretch">
                <Rectangle.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="ShowSidebar"/>
                        <Binding Path="!IsViewerFullScreen"/>
                    </MultiBinding>
                </Rectangle.IsVisible>
            </Rectangle>

            <!-- ── Artist sidebar — hidden when viewer is full-screen or sidebar toggled off ── -->
            <Border Grid.Column="0"
                    Background="{actipro:ThemeResource Container1BackgroundBrush}"
                    BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Border.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="ShowSidebar"/>
                        <Binding Path="!IsViewerFullScreen"/>
                    </MultiBinding>
                </Border.IsVisible>
                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Search bar — stretches full width -->
                    <Border Grid.Row="0" Margin="10,10,10,8"
                            Background="{actipro:ThemeResource Container2BackgroundBrush}"
                            CornerRadius="10" BorderThickness="0">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="12" Margin="12,0,6,0"
                                       VerticalAlignment="Center" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                            <TextBox Grid.Column="1" Text="{Binding ArtistFilter}"
                                     PlaceholderText="Filter artists…"
                                     CornerRadius="0" FontSize="12"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="0,9"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Margin="10,0,10,0"
                            Background="{actipro:ThemeResource Container2BackgroundBrush}"
                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                            BorderThickness="1" CornerRadius="12"
                            ClipToBounds="True">
                    <ListBox ItemsSource="{Binding FilteredArtists}"
                             SelectedItem="{Binding SelectedArtist}"
                             Background="Transparent" Padding="6,4,6,6"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerTheme>
                            <ControlTheme TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,7"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <Border Name="Root"
                                                Background="Transparent"
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter>
                                <Style Selector="^:pointerover /template/ Border#Root">
                                    <Setter Property="Background" Value="#14FFFFFF"/>
                                </Style>
                                <Style Selector="^:selected /template/ Border#Root">
                                    <Setter Property="Background" Value="#1E4A7FBF"/>
                                </Style>
                                <Style Selector="^:selected:pointerover /template/ Border#Root">
                                    <Setter Property="Background" Value="#2E4A7FBF"/>
                                </Style>
                            </ControlTheme>
                        </ListBox.ItemContainerTheme>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ArtistCardViewModel">
                                <Grid ColumnDefinitions="3,Auto,*,Auto" VerticalAlignment="Center"
                                      PointerPressed="OnArtistRowPointerPressed"
                                      Tag="{Binding UserId}">
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Open artist page" Click="OnOpenArtistPageMenu">
                                                <MenuItem.Tag>
                                                    <Binding Path="UserId"/>
                                                </MenuItem.Tag>
                                            </MenuItem>
                                            <MenuItem Header="Copy ID" Click="OnCopyArtistIdMenu">
                                                <MenuItem.Tag>
                                                    <Binding Path="UserId"/>
                                                </MenuItem.Tag>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <!-- Left accent bar — visible when selected -->
                                    <Border Grid.Column="0" Width="3" Height="20" CornerRadius="2"
                                            Background="#5B8DEF" VerticalAlignment="Center"
                                            IsVisible="{Binding $parent[ListBoxItem].IsSelected}"/>
                                    <!-- Avatar -->
                                    <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18"
                                            ClipToBounds="True"
                                            Background="{actipro:ThemeResource Container2BackgroundBrush}">
                                        <Panel>
                                            <TextBlock Text="{Binding Initial}"
                                                       FontSize="14" FontWeight="SemiBold" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding Avatar, Converter={x:Static ObjectConverters.IsNull}}"/>
                                            <Image Source="{Binding Avatar}" Stretch="UniformToFill"
                                                   IsVisible="{Binding Avatar, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        </Panel>
                                    </Border>
                                    <!-- Name + ID -->
                                    <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="ArtistIdText"
                                                   Text="{Binding UserId, StringFormat='ID {0}'}"
                                                   FontSize="11"
                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                   Cursor="IBeam"
                                                   TextTrimming="CharacterEllipsis"
                                                   PointerPressed="OnArtistIdPointerPressed"
                                                   Tag="{Binding UserId}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </Border>

                    <!-- R-18 toggle at the bottom of the sidebar -->
                    <Border Grid.Row="2" Margin="10,6,10,10"
                            Background="{actipro:ThemeResource Container2BackgroundBrush}"
                            CornerRadius="10" BorderThickness="0"
                            IsVisible="{Binding ShowR18Buttons}">
                        <Grid ColumnDefinitions="*,Auto" Margin="14,12">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="R-18 Content" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="Show explicit content" FontSize="10"
                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"/>
                            </StackPanel>
                            <!-- Pill toggle switch -->
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowR18}"
                                          VerticalAlignment="Center"
                                          Width="44" Height="24"
                                          Padding="0" CornerRadius="12"
                                          Background="Transparent" BorderThickness="0"
                                          ToolTip.Tip="Show / hide R-18 content">
                                <ToggleButton.Styles>
                                    <Style Selector="ToggleButton">
                                        <Setter Property="Template">
                                            <ControlTemplate>
                                                <Border Width="44" Height="24" CornerRadius="12"
                                                        Background="#374151">
                                                    <Border.Styles>
                                                        <Style Selector="Border:pointerover">
                                                            <Setter Property="Background" Value="#4B5563"/>
                                                        </Style>
                                                    </Border.Styles>
                                                    <Canvas Width="44" Height="24" ClipToBounds="False">
                                                        <Ellipse Width="18" Height="18"
                                                                 Canvas.Left="3" Canvas.Top="3"
                                                                 Fill="White" Opacity="0.5"/>
                                                    </Canvas>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter>
                                    </Style>
                                    <Style Selector="ToggleButton:checked">
                                        <Setter Property="Template">
                                            <ControlTemplate>
                                                <Border Width="44" Height="24" CornerRadius="12"
                                                        Background="#EF4444">
                                                    <Canvas Width="44" Height="24" ClipToBounds="False">
                                                        <Ellipse Width="18" Height="18"
                                                                 Canvas.Left="23" Canvas.Top="3"
                                                                 Fill="White"/>
                                                    </Canvas>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Styles>
                            </ToggleButton>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{actipro:ThemeResource Container1BorderBrush}"/>

            <!-- ── Artwork area: grid | optional preview side panel ─────────── -->
            <Grid Grid.Column="2" x:Name="ContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="280"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto" MinWidth="0"/>
                </Grid.ColumnDefinitions>

                <!-- Custom splitter (Border with pointer events) — avoids GridSplitter's direct column manipulation -->
                <Border Grid.Column="1" Width="4" Name="GallerySplitter"
                        Cursor="SizeWestEast"
                        Background="{actipro:ThemeResource Container1BorderBrush}"
                        IsVisible="{Binding ShowPreview}"
                        PointerPressed="OnSplitterPointerPressed"
                        PointerMoved="OnSplitterPointerMoved"
                        PointerReleased="OnSplitterPointerReleased"/>

                <!-- Side preview panel -->
                <Border Grid.Column="2"
                        IsVisible="{Binding ShowPreview}">
                    <Border
                        Width="{Binding BrowsePanelWidth}"
                        MinWidth="320"
                        ClipToBounds="True"
                        Background="{actipro:ThemeResource Container1BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                        BorderThickness="1,0,0,0">
                        <local:InlineArtworkViewer x:Name="GallerySideViewer"
                                                   DataContext="{Binding}"
                                                   IsExpanded="{Binding IsViewerExpanded}"/>
                    </Border>
                </Border>


                <!-- ── Main content area (full-screen viewer OR grid/list) ── -->
                <Border Grid.Column="0"
                        Background="{actipro:ThemeResource Container3BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10" Margin="8,8,8,8"
                        ClipToBounds="True">

                <!-- ─── GRID / LIST layer ─── -->
                <Grid IsVisible="{Binding ShowGridLayer}">

                    <!-- Empty / select-artist hint -->
                    <StackPanel Grid.Row="0"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                                ZIndex="1">
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="SelectedArtist" Converter="{x:Static ObjectConverters.IsNull}"/>
                                <Binding Path="!IsRecentFeedActive"/>
                                <Binding Path="!IsLoading"/>
                                <Binding Path="!HasArtworks"/>
                            </MultiBinding>
                        </StackPanel.IsVisible>
                        <TextBlock Text="Select an artist to view their works"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="←  Choose from the sidebar, or click Recent Works"
                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- ── GRID view ──────────────────────────────── -->
                    <ScrollViewer Grid.Row="0" Name="GridScroll"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  AllowAutoHide="False"
                                  IsVisible="{Binding IsGridView}">
                        <ItemsControl ItemsSource="{Binding FilteredArtworks}" Margin="10,10,4,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <local:MasonryPanel x:Name="ArtworksPanel"
                                                        ColumnWidth="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).CardSize}"
                                                        ItemSpacing="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ArtworkCardViewModel">
                                    <Panel>
                                        <!-- FIXED HEIGHT MODE: Seamless cropped images, clean layout -->
                                        <Border Margin="0,0,2,2"
                                                IsVisible="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).IsFixedHeight}"
                                                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                BorderThickness="1" CornerRadius="8"
                                                BoxShadow="0 1 4 0 #28000000"
                                                Cursor="Hand"
                                                PointerPressed="OnArtworkCardClicked">
                                                <Border.ContextMenu>
                                                    <ContextMenu Opening="OnCardContextMenuOpening">
                                                        <MenuItem Header="☑ Select" Click="OnContextToggleSelection"
                                                                  IsVisible="{Binding !IsSelected}"/>
                                                        <MenuItem Header="☒ Deselect" Click="OnContextToggleSelection"
                                                                  IsVisible="{Binding IsSelected}"/>
                                                        <Separator/>
                                                        <MenuItem Header="↓ Download all" Click="OnContextDownloadAll"/>
                                                        <MenuItem Header="↓ First page only" Click="OnContextDownloadThisPage"
                                                                  IsVisible="{Binding IsMultiPage}"/>
                                                        <Separator/>
                                                        <MenuItem Header="👁 Open in side panel" Click="OnContextOpenSidePanel"/>
                                                        <MenuItem Header="⛶ Open full screen" Click="OnContextOpenFullScreen"/>
                                                        <MenuItem Header="⊞ Open in new tab" Click="OnContextOpenInNewTab"/>
                                                        <MenuItem Header="⧉ Open in popup" Click="OnContextOpenPopup"/>
                                                        <MenuItem Header="🌐 Open on pixiv.net" Click="OnContextOpenPixiv"/>
                                                        <MenuItem Header="👤 Open artist gallery" Click="OnContextOpenArtistGallery"
                                                                  Tag="OpenArtistGallery"
                                                                  IsVisible="{Binding !IsCurrentArtist}"/>
                                                        <Separator/>
                                                        <MenuItem Header="★ Add to local favorites" Click="OnContextToggleFavorite"
                                                                  IsVisible="{Binding !IsLocalFavorite}"/>
                                                        <MenuItem Header="★ Remove from favorites" Click="OnContextToggleFavorite"
                                                                  IsVisible="{Binding IsLocalFavorite}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Copy ID" Click="OnContextCopyId"/>
                                                        <MenuItem Header="📋 Copy image" Click="OnContextCopyImage"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="BoxShadow" Value="0 6 20 0 #55000000"/>
                                                    <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"/>
                                                </Style>
                                            </Border.Styles>
                                            <Grid RowDefinitions="*,Auto">
                                                <!-- Image area: clipped top corners only — image ONLY inside clip -->
                                                <Border Grid.Row="0"
                                                        Height="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).FixedCardTotalHeight}"
                                                        CornerRadius="7,7,0,0" ClipToBounds="True">
                                                    <Panel>
                                                        <!-- Loading placeholder — visible until thumbnail loads -->
                                                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                               HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                            <Image.Effect>
                                                                <BlurEffect Radius="{Binding IsBlurred, Converter={StaticResource BoolToBlurRadiusConverter}}" />
                                                            </Image.Effect>
                                                        </Image>
                                                    </Panel>
                                                </Border>
                                                <!-- Badges overlaid on image row — outside ClipToBounds -->
                                                <Panel Grid.Row="0" ZIndex="5" IsHitTestVisible="False">
                                                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                            Margin="6,0,0,6" Padding="5,2" CornerRadius="4"
                                                            Background="#BB000000" IsVisible="{Binding IsMultiPage}">
                                                        <TextBlock Text="{Binding PageCount, StringFormat='1/{0}'}"
                                                                   FontSize="9" Foreground="White"/>
                                                    </Border>
                                                    <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                            Margin="0,6,6,0" Padding="5,2" CornerRadius="4"
                                                            Background="#CCDC2626" IsVisible="{Binding IsR18}">
                                                        <TextBlock Text="R-18" FontSize="8" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                    <Border Background="#AA000000" IsVisible="{Binding IsDownloading}" IsHitTestVisible="True">
                                                        <ProgressBar IsIndeterminate="True" Width="60" Height="3"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </Panel>
                                                <!-- Selection checkbox — top-left (always inside card bounds) -->
                                                <CheckBox Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Left"
                                                          Margin="6,6,0,0" ZIndex="10" MinWidth="0" MinHeight="0"
                                                          IsChecked="{Binding IsSelected}" Click="OnArtworkCheckboxClicked"/>
                                                <!-- Info strip below image -->
                                                <StackPanel Grid.Row="1" Margin="8,6,8,8" Spacing="2"
                                                            IsVisible="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).ShowInfo}">
                                                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrush}"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <TextBlock Text="{Binding DateLabel}" FontSize="10"
                                                               IsVisible="{Binding HasDate}"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                    <ItemsControl ItemsSource="{Binding TopTags}" Margin="0,2,0,0"
                                                                  IsVisible="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).ShowTags}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="x:String">
                                                                <Border Margin="0,1,3,1" Padding="5,2" CornerRadius="3"
                                                                        Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                        BorderThickness="0"
                                                                        Cursor="Hand" PointerPressed="OnTagChipPressed">
                                                                    <Border.Styles>
                                                                        <Style Selector="Border:pointerover">
                                                                            <Setter Property="Background" Value="Transparent"/>
                                                                            <Setter Property="BorderThickness" Value="0"/>
                                                                        </Style>
                                                                        <Style Selector="Border:pointerover TextBlock">
                                                                            <Setter Property="TextDecorations" Value="Underline"/>
                                                                            <Setter Property="Foreground" Value="#5B8DEF"/>
                                                                        </Style>
                                                                    </Border.Styles>
                                                                    <TextBlock Text="{Binding}" FontSize="11"
                                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- NATURAL HEIGHT MODE: Full images with aspect ratio preservation -->
                                        <Border Margin="0,0,2,2"
                                                Width="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).CardSize}"
                                                IsVisible="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).IsNaturalHeight}"
                                                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                                BorderThickness="1" CornerRadius="8"
                                                BoxShadow="0 1 4 0 #28000000"
                                                Cursor="Hand"
                                                PointerPressed="OnArtworkCardClicked">
                                                <Border.ContextMenu>
                                                    <ContextMenu Opening="OnListCardContextMenuOpening">
                                                        <MenuItem Header="☑ Select" Click="OnContextToggleSelection"
                                                                  IsVisible="{Binding !IsSelected}"/>
                                                        <MenuItem Header="☒ Deselect" Click="OnContextToggleSelection"
                                                                  IsVisible="{Binding IsSelected}"/>
                                                        <Separator/>
                                                        <MenuItem Header="↓ Download all" Click="OnContextDownloadAll"/>
                                                        <MenuItem Header="↓ First page only" Click="OnContextDownloadThisPage"
                                                                  IsVisible="{Binding IsMultiPage}"/>
                                                        <Separator/>
                                                        <MenuItem Header="👁 Open in side panel" Click="OnContextOpenSidePanel"/>
                                                        <MenuItem Header="⛶ Open full screen" Click="OnContextOpenFullScreen"/>
                                                        <MenuItem Header="⊞ Open in new tab" Click="OnContextOpenInNewTab"/>
                                                        <MenuItem Header="⧉ Open in popup" Click="OnContextOpenPopup"/>
                                                        <MenuItem Header="🌐 Open on pixiv.net" Click="OnContextOpenPixiv"/>
                                                        <MenuItem Header="👤 Open artist gallery" Click="OnContextOpenArtistGallery"
                                                                  Tag="OpenArtistGallery"
                                                                  IsVisible="{Binding !IsCurrentArtist}"/>
                                                        <Separator/>
                                                        <MenuItem Header="★ Add to local favorites" Click="OnContextToggleFavorite"
                                                                  IsVisible="{Binding !IsLocalFavorite}"/>
                                                        <MenuItem Header="★ Remove from favorites" Click="OnContextToggleFavorite"
                                                                  IsVisible="{Binding IsLocalFavorite}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Copy ID" Click="OnContextCopyId"/>
                                                        <MenuItem Header="📋 Copy image" Click="OnContextCopyImage"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="BoxShadow" Value="0 6 20 0 #55000000"/>
                                                    <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"/>
                                                </Style>
                                            </Border.Styles>
                                            <Grid RowDefinitions="*,Auto">
                                                <!-- Image area: natural height, clipped top corners — image ONLY inside clip -->
                                                <Border Grid.Row="0" CornerRadius="7,7,0,0" ClipToBounds="True">
                                                    <Panel>
                                                        <!-- Loading placeholder — visible until thumbnail loads -->
                                                        <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                               HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                            <Image.Height>
                                                                <MultiBinding Converter="{x:Static conv:MultiplyByAspectRatioConverter.Instance}">
                                                                    <Binding Path="$parent[UserControl].((vm:GalleryViewModel)DataContext).CardSize"/>
                                                                    <Binding Path="ClampedAspectRatio"/>
                                                                </MultiBinding>
                                                            </Image.Height>
                                                            <Image.Effect>
                                                                <BlurEffect Radius="{Binding IsBlurred, Converter={StaticResource BoolToBlurRadiusConverter}}" />
                                                            </Image.Effect>
                                                        </Image>
                                                    </Panel>
                                                </Border>
                                                <!-- Badges overlaid on image row — outside ClipToBounds -->
                                                <Panel Grid.Row="0" ZIndex="5" IsHitTestVisible="False">
                                                    <Panel.Height>
                                                        <MultiBinding Converter="{x:Static conv:MultiplyByAspectRatioConverter.Instance}">
                                                            <Binding Path="$parent[UserControl].((vm:GalleryViewModel)DataContext).CardSize"/>
                                                            <Binding Path="ClampedAspectRatio"/>
                                                        </MultiBinding>
                                                    </Panel.Height>
                                                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                            Margin="6,0,0,6" Padding="5,2" CornerRadius="4"
                                                            Background="#BB000000" IsVisible="{Binding IsMultiPage}">
                                                        <TextBlock Text="{Binding PageCount, StringFormat='1/{0}'}"
                                                                   FontSize="9" Foreground="White"/>
                                                    </Border>
                                                    <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                            Margin="0,6,6,0" Padding="5,2" CornerRadius="4"
                                                            Background="#CCDC2626" IsVisible="{Binding IsR18}">
                                                        <TextBlock Text="R-18" FontSize="8" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                    <Border Background="#AA000000" IsVisible="{Binding IsDownloading}" IsHitTestVisible="True">
                                                        <ProgressBar IsIndeterminate="True" Width="60" Height="3"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </Panel>
                                                <!-- Selection checkbox — top-left (always inside card bounds) -->
                                                <CheckBox Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Left"
                                                          Margin="6,6,0,0" ZIndex="10" MinWidth="0" MinHeight="0"
                                                          IsChecked="{Binding IsSelected}" Click="OnArtworkCheckboxClicked"/>
                                                <!-- Info strip below image -->
                                                <StackPanel Grid.Row="1" Margin="8,6,8,8" Spacing="2"
                                                            IsVisible="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).ShowInfo}">
                                                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrush}"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <TextBlock Text="{Binding DateLabel}" FontSize="10"
                                                               IsVisible="{Binding HasDate}"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                    <ItemsControl ItemsSource="{Binding TopTags}" Margin="0,2,0,0"
                                                                  IsVisible="{Binding $parent[UserControl].((vm:GalleryViewModel)DataContext).ShowTags}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="x:String">
                                                                <Border Margin="0,1,3,1" Padding="5,2" CornerRadius="3"
                                                                        Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                        BorderThickness="0"
                                                                        Cursor="Hand" PointerPressed="OnTagChipPressed">
                                                                    <Border.Styles>
                                                                        <Style Selector="Border:pointerover">
                                                                            <Setter Property="Background" Value="Transparent"/>
                                                                            <Setter Property="BorderThickness" Value="0"/>
                                                                        </Style>
                                                                        <Style Selector="Border:pointerover TextBlock">
                                                                            <Setter Property="TextDecorations" Value="Underline"/>
                                                                            <Setter Property="Foreground" Value="#5B8DEF"/>
                                                                        </Style>
                                                                    </Border.Styles>
                                                                    <TextBlock Text="{Binding}" FontSize="11"
                                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <!-- Selection state overlay: accent border around card -->
                                        <Border Margin="0,0,6,6"
                                                IsVisible="{Binding IsSelected}"
                                                IsHitTestVisible="False"
                                                BorderBrush="#5B8DEF" BorderThickness="2"
                                                CornerRadius="8"/>
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- ── LIST view ──────────────────────────────── -->
                    <ScrollViewer Grid.Row="0" Name="ListScroll" Padding="10,10,10,4"
                                  IsVisible="{Binding IsListView}">
                        <ItemsControl ItemsSource="{Binding FilteredArtworks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ArtworkCardViewModel">
                                    <Border Margin="0,0,0,3"
                                            Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Padding="6"
                                            Cursor="Hand"
                                            PointerPressed="OnArtworkCardClicked">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="☑ Select" Click="OnContextToggleSelection"
                                                              IsVisible="{Binding !IsSelected}"/>
                                                    <MenuItem Header="☒ Deselect" Click="OnContextToggleSelection"
                                                              IsVisible="{Binding IsSelected}"/>
                                                    <Separator/>
                                                    <MenuItem Header="↓ Download all" Click="OnContextDownloadAll"/>
                                                    <MenuItem Header="↓ First page only" Click="OnContextDownloadThisPage"
                                                              IsVisible="{Binding IsMultiPage}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Open popup" Click="OnContextOpenPopup"/>
                                                    <MenuItem Header="Open in new tab" Click="OnContextOpenInNewTab"/>
                                                    <MenuItem Header="Open on pixiv.net" Click="OnContextOpenPixiv"/>
                                                    <MenuItem Header="👤 Open artist gallery" Click="OnContextOpenArtistGallery"
                                                              Tag="OpenArtistGallery"/>
                                                    <Separator/>
                                                    <MenuItem Header="★ Add to local favorites" Click="OnContextToggleFavorite"
                                                              IsVisible="{Binding !IsLocalFavorite}"/>
                                                    <MenuItem Header="★ Remove from favorites" Click="OnContextToggleFavorite"
                                                              IsVisible="{Binding IsLocalFavorite}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Copy ID" Click="OnContextCopyId"/>
                                                    <MenuItem Header="📋 Copy image" Click="OnContextCopyImage"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center" Click="OnArtworkCheckboxClicked"/>
                                            <Border Grid.Column="1" Width="56" Height="56" CornerRadius="4"
                                                    ClipToBounds="True" Margin="4,0,10,0"
                                                    Background="{actipro:ThemeResource Container2BackgroundBrush}">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="3">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding TypeLabel}" FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                    <TextBlock Text="{Binding DateLabel}" FontSize="11"
                                                               IsVisible="{Binding HasDate}"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                    <TextBlock Text="{Binding PageCount, StringFormat='{}{0} pages'}"
                                                               FontSize="11" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}" IsVisible="{Binding IsMultiPage}"/>
                                                    <Border Background="#CCDC2626" CornerRadius="3" Padding="4,1" IsVisible="{Binding IsR18}">
                                                        <TextBlock Text="R-18" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <ProgressBar Grid.Column="3" IsIndeterminate="True" Width="40" Height="3"
                                                         IsVisible="{Binding IsDownloading}" VerticalAlignment="Center" Margin="8,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Loading overlay -->
                    <Border Grid.Row="0" Background="#AA000000"
                            IsVisible="{Binding IsLoading}" PointerPressed="SwallowPointer">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                            <ProgressBar IsIndeterminate="True" Width="200"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{actipro:ThemeResource DefaultForegroundBrush}"
                                       FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- No separate bottom bar — action buttons live in the global status bar -->
                </Grid>

                </Border>
            </Grid>

        </Grid>

        <!-- Full-screen viewer overlay — covers entire view incl. toolbars -->
        <local:InlineArtworkViewer x:Name="GalleryFullViewer"
                                    Grid.Row="0" Grid.RowSpan="4"
                                    Margin="0,32,0,0"
                                    IsVisible="{Binding IsViewerExpanded}"
                                    IsExpanded="{Binding IsViewerExpanded}"
                                    ZIndex="10"
                                    DataContext="{Binding}"/>

        <!-- ── Status bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,1,0,0" Padding="14,9">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" FontSize="11"
                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                           Text="{Binding StatusMessage}" VerticalAlignment="Center"/>

                <!-- Pagination controls at bottom -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,20,0">
                    <!-- Pagination Toggle -->
                    <ToggleButton IsChecked="{Binding UsePagination, Mode=TwoWay}"
                                  CornerRadius="6" Padding="8,4" FontSize="11"
                                  ToolTip.Tip="Toggle pagination (off = show all, on = paginated)">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="📄" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="Pages" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Items per page selector (visible when pagination enabled) -->
                    <ComboBox IsVisible="{Binding UsePagination}"
                              SelectedItem="{Binding ItemsPerPage, Mode=TwoWay}"
                              ItemsSource="{Binding ItemsPerPageOptions}"
                              CornerRadius="6" Width="60" FontSize="11"
                              ToolTip.Tip="Items per page"/>

                    <!-- Page navigation (visible when pagination enabled) -->
                    <StackPanel IsVisible="{Binding UsePagination}" Orientation="Horizontal" Spacing="4">
                        <!-- First page -->
                        <Button Command="{Binding FirstPageCommand}"
                                IsEnabled="{Binding CanGoPrevious}"
                                CornerRadius="6" Padding="8,4" FontSize="11"
                                ToolTip.Tip="Go to first page">|←</Button>

                        <!-- Previous page -->
                        <Button Command="{Binding PreviousPageCommand}"
                                IsEnabled="{Binding CanGoPrevious}"
                                CornerRadius="6" Padding="8,4" FontSize="11"
                                ToolTip.Tip="Previous page">←</Button>

                        <!-- Page input -->
                        <TextBox Text="{Binding CurrentPage, Mode=TwoWay}"
                                 Width="40"
                                 CornerRadius="6"
                                 FontSize="11"
                                 HorizontalContentAlignment="Center"
                                 VerticalAlignment="Center"
                                 ToolTip.Tip="Enter page number and press Enter to jump"/>

                        <TextBlock Text="/" VerticalAlignment="Center" FontSize="11" Margin="2,0"/>
                        <TextBlock Text="{Binding TotalPages, StringFormat='{}{0}'}" VerticalAlignment="Center" FontSize="11" Margin="0,0,2,0"/>

                        <!-- Next page -->
                        <Button Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding CanGoNext}"
                                CornerRadius="6" Padding="8,4" FontSize="11"
                                ToolTip.Tip="Next page">→</Button>

                        <!-- Last page -->
                        <Button Command="{Binding LastPageCommand}"
                                IsEnabled="{Binding CanGoNext}"
                                CornerRadius="6" Padding="8,4" FontSize="11"
                                ToolTip.Tip="Go to last page">→|</Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                               Text="{Binding SelectedCount, StringFormat='{}{0} selected'}"
                               IsVisible="{Binding SelectedCount}"
                               VerticalAlignment="Center"/>
                    <Rectangle Width="1" Height="14" Fill="{actipro:ThemeResource Container1BorderBrush}"
                               IsVisible="{Binding SelectedArtist, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <Button Content="Select All" CornerRadius="6" Padding="8,4" FontSize="11"
                            Command="{Binding SelectAllCommand}"
                            IsVisible="{Binding SelectedArtist, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <Button Content="Clear" CornerRadius="6" Padding="8,4" FontSize="11"
                            Command="{Binding ClearSelectionCommand}"
                            IsVisible="{Binding SelectedCount}"/>
                    <Button Content="Load All into View" CornerRadius="6" Padding="8,4" FontSize="11"
                            Command="{Binding LoadAllArtworksCommand}"
                            IsVisible="{Binding CanLoadMore}"
                            ToolTip.Tip="Load every artwork into the grid (may take a moment)"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
