<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Pixora.Avalonia.Views.Login.PixivLoginWindow"
        Title="Sign in to Pixiv"
        Width="900" Height="680"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#1F2937" Padding="16,10">
            <StackPanel Spacing="2">
                <TextBlock Text="Sign in to Pixiv" FontSize="14" FontWeight="SemiBold" Foreground="#F9FAFB"/>
                <TextBlock x:Name="StatusText"
                           Text="Sign in with your Pixiv account below. Your session will be captured automatically."
                           FontSize="12" Foreground="#9CA3AF"/>
            </StackPanel>
        </Border>

        <!-- WebView -->
        <NativeWebView Grid.Row="1"
                       x:Name="WebView"
                       Source="https://accounts.pixiv.net/login?lang=en&amp;source=pc&amp;view_type=page"
                       NavigationCompleted="WebView_NavigationCompleted"/>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#1F2937" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click" CornerRadius="6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
