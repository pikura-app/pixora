<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
             xmlns:vm="using:Pixora.Avalonia.ViewModels"
             xmlns:conv="using:Pixora.Avalonia.Converters"
             xmlns:sys="using:System"
             xmlns:gallery="using:Pixora.Avalonia.Views.Gallery"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Pixora.Avalonia.Views.Rankings.EnhancedRankingsView"
             x:DataType="vm:EnhancedRankingsViewModel">

    <UserControl.Resources>
        <x:Double x:Key="SliderMin">100</x:Double>
        <x:Double x:Key="SliderMax">320</x:Double>

        <!-- Converter for R-18 blur effect -->
        <conv:BoolToBlurRadiusConverter x:Key="BoolToBlurRadiusConverter" />

        <!-- Shared context menu — DataContext is RankingCardViewModel -->
        <ContextMenu x:Key="RankingCardContextMenu" x:DataType="vm:RankingCardViewModel">
            <MenuItem Header="👁 Open in side panel" Click="OnContextPreview"
                      ToolTip.Tip="Open in the inline viewer with side panel visible"/>
            <MenuItem Header="⛶ Open full screen" Click="OnContextOpenFullScreen"
                      ToolTip.Tip="Open in the inline viewer in full-screen mode"/>
            <MenuItem Header="⊞ Open in new tab" Click="OnContextOpenInNewTab"
                      ToolTip.Tip="Open this artwork in a new viewer tab"/>
            <MenuItem Header="⧉ Open in popup window" Click="OnContextOpenPopup"
                      ToolTip.Tip="Open in a floating window"/>
            <Separator/>
            <MenuItem Header="☑ Select" Click="OnContextToggleSelection"
                      IsVisible="{Binding !IsSelected}"
                      ToolTip.Tip="Add to bulk selection"/>
            <MenuItem Header="☒ Deselect" Click="OnContextToggleSelection"
                      IsVisible="{Binding IsSelected}"/>
            <Separator/>
            <MenuItem Header="👤 Open artist gallery" Click="OnContextOpenArtistGallery"
                      ToolTip.Tip="Switch to the Gallery tab and load this artist"/>
            <MenuItem Header="🌐 Open on pixiv.net" Click="OnContextOpenPixiv"/>
            <MenuItem Header="🌐 Open artist on pixiv" Click="OnContextOpenArtist"/>
            <Separator/>
            <MenuItem Header="★ Add to local favorites" Click="OnContextAddFavorite" IsVisible="{Binding !IsSelected}"/>
            <MenuItem Header="★ Remove from favorites" Click="OnContextRemoveFavorite" IsVisible="{Binding IsSelected}"/>
            <Separator/>
            <MenuItem Header="Copy artwork ID" Click="OnContextCopyId"/>
            <MenuItem Header="Copy artwork URL" Click="OnContextCopyUrl"/>
            <MenuItem Header="📋 Copy image" Click="OnContextCopyImage"/>
        </ContextMenu>
    </UserControl.Resources>

    <!-- title | tabs+view | modes | actions | grid | status -->
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

        <!-- ══ Row 0: Title + date controls ══ -->
        <Border Grid.Row="0"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,10"
                Margin="0,32,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Rankings" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="70" Height="3"
                                 IsVisible="{Binding IsLoading}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Date toolbar — centred, grouped in a single rounded container -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                            BorderThickness="1" CornerRadius="7" Padding="3">
                        <Border.Styles>
                            <!-- All buttons inside the toolbar share a flat compact style -->
                            <Style Selector="Button.tool">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="CornerRadius" Value="5"/>
                                <Setter Property="Padding" Value="7,4"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="MinWidth" Value="0"/>
                            </Style>
                            <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{actipro:ThemeResource Container3BackgroundBrush}"/>
                            </Style>
                        </Border.Styles>
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <!-- ‹ = newer (toward today); hidden when already on latest -->
                            <Button Classes="tool" Content="‹"
                                    Command="{Binding GoToNextDateCommand}"
                                    IsVisible="{Binding NextDate, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    ToolTip.Tip="Newer date"/>
                            <!-- Calendar popup trigger -->
                            <Button Name="CalendarFlyoutButton" Classes="tool" Content="📅"
                                    FontSize="12" ToolTip.Tip="Pick a date">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom" ShowMode="Standard"
                                            Opened="OnCalendarOpened">
                                        <Calendar Name="DatePopupCalendar"
                                                  SelectionMode="SingleDate"
                                                  SelectedDatesChanged="OnCalendarSelectedDateChanged"/>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <!-- Manual date input -->
                            <TextBox Text="{Binding DateInput}"
                                     Watermark="YYYY-MM-DD"
                                     Width="100" BorderThickness="0"
                                     Background="Transparent"
                                     Padding="6,4" FontSize="11"
                                     VerticalContentAlignment="Center"
                                     KeyDown="OnDateInputKeyDown"
                                     ToolTip.Tip="Type YYYY-MM-DD and press Enter"/>
                            <!-- Reset to Latest -->
                            <Button Classes="tool" Content="⊙" FontSize="12"
                                    Command="{Binding GoToLatestCommand}"
                                    IsVisible="{Binding NextDate, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    ToolTip.Tip="Reset to latest ranking"/>
                            <!-- › = older -->
                            <Button Classes="tool" Content="›"
                                    Command="{Binding GoToPrevDateCommand}"
                                    IsEnabled="{Binding PrevDate, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    ToolTip.Tip="Older date"/>
                        </StackPanel>
                    </Border>
                    <Button CornerRadius="6" Padding="9,5" FontSize="12"
                            Command="{Binding ReloadCommand}" ToolTip.Tip="Reload">⟳</Button>
                </StackPanel>

                <!-- R-18 toggle — right -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                            IsVisible="{Binding ShowR18Buttons}">
                    <ToggleButton IsChecked="{Binding ShowR18}" CornerRadius="8" Padding="8,4"
                                  FontSize="11"
                                  ToolTip.Tip="Show R-18 rankings">
                        <ToggleButton.Styles>
                            <Style Selector="ToggleButton:checked">
                                <Setter Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                            <Style Selector="ToggleButton:not(:checked)">
                                <Setter Property="Background" Value="{actipro:ThemeResource Container3BackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{actipro:ThemeResource DefaultForegroundBrushSecondary}"/>
                            </Style>
                        </ToggleButton.Styles>
                        R-18
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Row 1: Content tabs (left) + view/size controls (right) ══ -->
        <Border Grid.Row="1"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,7">
            <Grid ColumnDefinitions="*,Auto">
                <!-- LEFT: content type tabs -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Content="Overall"      CornerRadius="6" Padding="14,5" FontSize="12"
                            Command="{Binding SelectContentCommand}" CommandParameter="all"
                            Classes.accent="{Binding SelectedContent, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=all}"/>
                    <Button Content="Illustrations" CornerRadius="6" Padding="14,5" FontSize="12"
                            Command="{Binding SelectContentCommand}" CommandParameter="illust"
                            Classes.accent="{Binding SelectedContent, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=illust}"/>
                    <Button Content="Ugoira"        CornerRadius="6" Padding="14,5" FontSize="12"
                            Command="{Binding SelectContentCommand}" CommandParameter="ugoira"
                            Classes.accent="{Binding SelectedContent, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=ugoira}"/>
                    <Button Content="Manga"         CornerRadius="6" Padding="14,5" FontSize="12"
                            Command="{Binding SelectContentCommand}" CommandParameter="manga"
                            Classes.accent="{Binding SelectedContent, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=manga}"/>
                </StackPanel>
                <!-- RIGHT: grid/list | fixed/natural | size slider | info/tags -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                    <!-- Grid/List -->
                    <ToggleButton IsChecked="{Binding IsGridView}" CornerRadius="5" Padding="9,5" FontSize="11"
                                  Command="{Binding SetGridViewCommand}"
                                  ToolTip.Tip="Grid view">⊞ Grid</ToggleButton>
                    <ToggleButton IsChecked="{Binding IsListView}" CornerRadius="5" Padding="9,5" FontSize="11"
                                  Command="{Binding SetListViewCommand}"
                                  ToolTip.Tip="List view">☰ List</ToggleButton>
                    <Rectangle Width="1" Height="16" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="3,0"
                               IsVisible="{Binding IsGridView}"/>
                    <!-- Fixed / Natural height -->
                    <ToggleButton IsChecked="{Binding IsFixedHeight}" CornerRadius="5" Padding="9,5" FontSize="11"
                                  Command="{Binding SetFixedHeightCommand}"
                                  IsVisible="{Binding IsGridView}"
                                  ToolTip.Tip="Fixed card height - images cropped to fit">
                        <ToggleButton.Styles>
                            <Style Selector="ToggleButton:checked">
                                <Setter Property="Background" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </ToggleButton.Styles>
                        Fixed
                    </ToggleButton>
                    <ToggleButton IsChecked="{Binding IsNaturalHeight}" CornerRadius="5" Padding="9,5" FontSize="11"
                                  Command="{Binding SetNaturalHeightCommand}"
                                  IsVisible="{Binding IsGridView}"
                                  ToolTip.Tip="Natural card height - images show full aspect ratio">
                        <ToggleButton.Styles>
                            <Style Selector="ToggleButton:checked">
                                <Setter Property="Background" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </ToggleButton.Styles>
                        Natural
                    </ToggleButton>
                    <Rectangle Width="1" Height="16" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="3,0"
                               IsVisible="{Binding IsGridView}"/>
                    <!-- Card size slider -->
                    <Slider Value="{Binding CardSize}" Minimum="100" Maximum="320"
                            Width="90" VerticalAlignment="Center"
                            IsVisible="{Binding IsGridView}"
                            ToolTip.Tip="Card size"/>
                    <Rectangle Width="1" Height="16" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="3,0"/>
                    <!-- Side panel toggle -->
                    <ToggleButton IsChecked="{Binding ShowPreview}"
                                  CornerRadius="5" Padding="10,5" FontSize="11"
                                  ToolTip.Tip="Toggle the side panel (browse artworks alongside the viewer)">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="▣" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="Side Panel" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <Rectangle Width="1" Height="16" Fill="{actipro:ThemeResource Container1BorderBrush}" Margin="3,0"/>
                    <!-- Info / Tags -->
                    <ToggleButton IsChecked="{Binding ShowInfo}" CornerRadius="5" Padding="9,5" FontSize="11"
                                  ToolTip.Tip="Show/hide artwork info">Info</ToggleButton>
                    <ToggleButton IsChecked="{Binding ShowTags}" CornerRadius="5" Padding="9,5" FontSize="11"
                                  ToolTip.Tip="Show/hide tags">Tags</ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Row 2: Mode pills ══ -->
        <Border Grid.Row="2"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,7">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <!-- Overall modes: Daily, Weekly, AI, Male, Female -->
                <StackPanel Orientation="Horizontal" Spacing="4"
                            IsVisible="{Binding ShowOverallModes}">
                    <Button Content="Daily"    CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="daily"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=daily}"/>
                    <Button Content="Weekly"   CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="weekly"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=weekly}"/>
                    <Button Content="AI"       CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="daily_ai"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=daily_ai}"
                            IsVisible="{Binding ShowAiButton}"/>
                    <Button Content="Male"     CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="male"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=male}"/>
                    <Button Content="Female"   CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="female"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=female}"/>
                </StackPanel>

                <!-- Illustrations modes: Daily, Weekly only -->
                <StackPanel Orientation="Horizontal" Spacing="4"
                            IsVisible="{Binding ShowIllustModes}">
                    <Button Content="Daily"    CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="daily"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=daily}"/>
                    <Button Content="Weekly"   CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="weekly"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=weekly}"/>
                </StackPanel>

                <!-- Ugoira modes: Daily, Weekly only -->
                <StackPanel Orientation="Horizontal" Spacing="4"
                            IsVisible="{Binding ShowUgoiraModes}">
                    <Button Content="Daily"    CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="daily"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=daily}"/>
                    <Button Content="Weekly"   CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="weekly"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=weekly}"/>
                </StackPanel>

                <!-- Manga modes: Daily, Weekly only -->
                <StackPanel Orientation="Horizontal" Spacing="4"
                            IsVisible="{Binding ShowMangaModes}">
                    <Button Content="Daily"    CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="daily"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=daily}"/>
                    <Button Content="Weekly"   CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="weekly"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=weekly}"/>
                </StackPanel>

                <!-- Novel modes: Weekly, Monthly, Rookie only (novels don't have daily) -->
                <StackPanel Orientation="Horizontal" Spacing="4"
                            IsVisible="{Binding ShowNovelModes}">
                    <Button Content="Weekly"   CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="weekly"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=weekly}"/>
                    <Button Content="Monthly"  CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="monthly"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=monthly}"/>
                    <Button Content="Rookie"   CornerRadius="6" Padding="12,5" FontSize="11"
                            Command="{Binding SelectModeCommand}" CommandParameter="rookie"
                            Classes.accent="{Binding SelectedMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=rookie}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ Row 3: Action buttons ══ -->
        <Border Grid.Row="3"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button CornerRadius="6" Padding="12,6" FontSize="11"
                        Classes.accent="{Binding HasSelection}"
                        IsEnabled="{Binding HasSelection}"
                        Command="{Binding DownloadSelectedCommand}"
                        ToolTip.Tip="Download selected artworks">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="↓" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedCount, StringFormat='Download Selected ({0})'}" />
                    </StackPanel>
                </Button>
                <Button CornerRadius="6" Padding="12,6" FontSize="11"
                        Command="{Binding DownloadVisibleCommand}"
                        ToolTip.Tip="Download all visible artworks">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="⊞" FontSize="12"/>
                        <TextBlock Text="Download Visible"/>
                    </StackPanel>
                </Button>
                <Button Content="🎨 Download Preset" CornerRadius="6" Padding="12,6" FontSize="11"
                        Classes="accent"
                        Click="OnDownloadPresetClicked"
                        IsEnabled="{Binding !IsLoading}"
                        ToolTip.Tip="Download with image processing preset"/>
                <Button Content="{Binding SelectedCount, StringFormat='Clear ({0})'}"
                        CornerRadius="6" Padding="12,6" FontSize="11"
                        Command="{Binding ClearSelectionCommand}"
                        IsVisible="{Binding HasSelection}"/>
            </StackPanel>
        </Border>

        <!-- ══ Row 4: Artwork area ══ -->
        <Border Grid.Row="4"
                Background="{actipro:ThemeResource Container3BackgroundBrush}"
                Margin="0">
            <Grid Name="ContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="280"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0" MinWidth="0"/>
                </Grid.ColumnDefinitions>

                <!-- Draggable splitter (only when preview is on) -->
                <GridSplitter Grid.Column="1" Width="4"
                              Background="{actipro:ThemeResource Container1BorderBrush}"
                              IsVisible="{Binding ShowPreview}"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns"
                              DragCompleted="OnSplitterDragCompleted"/>

                <!-- Side preview panel -->
                <Border Grid.Column="2"
                        Background="{actipro:ThemeResource Container1BackgroundBrush}"
                        BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                        BorderThickness="1,0,0,0"
                        IsVisible="{Binding ShowPreview}">
                    <gallery:InlineArtworkViewer Name="RankingsInlineViewer"
                                                 DataContext="{Binding GalleryVm}"
                                                 IsExpanded="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).IsViewerExpanded}"/>
                </Border>

                <!-- Main artwork area -->
                <Panel Grid.Column="0">
                <!-- Empty / loading hint -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                            IsVisible="{Binding !FilteredItems.Count}">
                    <TextBlock Text="🏆 Loading rankings…" FontSize="15"
                               IsVisible="{Binding IsLoading}"
                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="🏆 No rankings to show"
                               IsVisible="{Binding !IsLoading}"
                               FontSize="15" Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               IsVisible="{Binding !IsLoading}"
                               FontSize="12" Foreground="{actipro:ThemeResource DefaultForegroundBrushDisabled}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ── GRID views ── -->
                <ScrollViewer Name="GridScrollViewer"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              AllowAutoHide="False"
                              IsVisible="{Binding IsGridView}"
                              ScrollChanged="OnScrollChanged">
                    <Panel>
                    <!-- Grid view: MasonryPanel for both Fixed and Natural height -->
                    <ItemsControl ItemsSource="{Binding FilteredItems}" Margin="10,10,4,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <gallery:MasonryPanel ColumnWidth="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).CardSize}" ItemSpacing="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RankingCardViewModel">
                                <Panel>
                                    <!-- ── FIXED HEIGHT card ── -->
                                    <Border Margin="0,0,6,6"
                                            Width="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).CardSize}"
                                            IsVisible="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).ShowFixedGrid}"
                                            Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                            BorderThickness="1" CornerRadius="8"
                                            BoxShadow="0 1 4 0 #28000000" Cursor="Hand"
                                            PointerPressed="OnCardClicked"
                                            ContextMenu="{StaticResource RankingCardContextMenu}">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="BoxShadow" Value="0 6 20 0 #55000000"/>
                                                <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"/>
                                            </Style>
                                        </Border.Styles>
                                        <Grid RowDefinitions="*,Auto">
                                            <Border Grid.Row="0"
                                                    Height="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).FixedCardTotalHeight}"
                                                    CornerRadius="7,7,0,0" ClipToBounds="True">
                                                <Panel>
                                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                            IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                        <Image.Effect>
                                                            <BlurEffect Radius="{Binding IsBlurred, Converter={StaticResource BoolToBlurRadiusConverter}}" />
                                                        </Image.Effect>
                                                    </Image>
                                                </Panel>
                                            </Border>
                                            <!-- badges -->
                                            <Panel Grid.Row="0" ZIndex="5" IsHitTestVisible="False">
                                                <!-- R-18 top-right -->
                                                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                        Margin="0,6,6,0" Padding="5,2" CornerRadius="4"
                                                        Background="#CCDC2626" IsVisible="{Binding IsR18}">
                                                    <TextBlock Text="R-18" FontSize="8" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                                <!-- Rank-change bottom-right -->
                                                <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                                        Margin="0,0,6,6" Padding="5,2" CornerRadius="4"
                                                        Background="#BB000000">
                                                    <TextBlock Text="{Binding RankChangeDisplay}" FontSize="9"
                                                               FontWeight="SemiBold" Foreground="{Binding RankChangeForeground}"/>
                                                </Border>
                                                <!-- Rank + page-count stacked bottom-left -->
                                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                            Margin="6,0,0,6" Spacing="3">
                                                    <Border Padding="6,3" CornerRadius="5" Background="#DD000000">
                                                        <TextBlock Text="{Binding Rank, StringFormat='#{0}'}"
                                                                   FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <Border Padding="5,2" CornerRadius="4" Background="#BB000000"
                                                            IsVisible="{Binding IsMultiPage}">
                                                        <TextBlock Text="{Binding PageCount, StringFormat='1/{0}'}"
                                                                   FontSize="9" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                            </Panel>
                                            <!-- selection checkbox — top-left -->
                                            <CheckBox Grid.Row="0" ZIndex="6"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Top" HorizontalAlignment="Left"
                                                      Margin="6,6,0,0" MinWidth="0" MinHeight="0"
                                                      Click="OnCardCheckboxClicked"/>
                                            <!-- info strip -->
                                            <StackPanel Grid.Row="1" Margin="8,5,8,7" Spacing="2"
                                                        IsVisible="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).ShowInfo}">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding Title}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrush}"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <TextBlock Grid.Column="1" FontSize="10"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                               Text="{Binding PageCount, StringFormat='1/{0}'}"
                                                               VerticalAlignment="Center" Margin="4,0,0,0"
                                                               IsVisible="{Binding IsMultiPage}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding UserName}" FontSize="10"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <!-- tags -->
                                                <ItemsControl ItemsSource="{Binding TopTags}" Margin="0,1,0,0"
                                                              IsVisible="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).ShowTags}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <Border Margin="0,1,3,1" Padding="5,2" CornerRadius="3"
                                                                    Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                    BorderThickness="0" Cursor="Hand"
                                                                    PointerPressed="OnTagChipPressed">
                                                                <Border.Styles>
                                                                    <Style Selector="Border:pointerover">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                    </Style>
                                                                    <Style Selector="Border:pointerover TextBlock">
                                                                        <Setter Property="TextDecorations" Value="Underline"/>
                                                                        <Setter Property="Foreground" Value="#5B8DEF"/>
                                                                    </Style>
                                                                </Border.Styles>
                                                                <TextBlock Text="{Binding}" FontSize="10"
                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- ── NATURAL HEIGHT card ── -->
                                    <Border Margin="0,0,6,6"
                                            Width="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).CardSize}"
                                            IsVisible="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).ShowNaturalGrid}"
                                            Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                            BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                            BorderThickness="1" CornerRadius="8"
                                            BoxShadow="0 1 4 0 #28000000" Cursor="Hand"
                                            PointerPressed="OnCardClicked"
                                            ContextMenu="{StaticResource RankingCardContextMenu}">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="BoxShadow" Value="0 6 20 0 #55000000"/>
                                                <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"/>
                                            </Style>
                                        </Border.Styles>
                                        <Grid RowDefinitions="*,Auto">
                                            <Border Grid.Row="0" CornerRadius="7,7,0,0" ClipToBounds="True">
                                                <Panel>
                                                    <Border Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                            IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                                    <!-- Natural height: Show full image at natural aspect ratio -->
                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                        <Image.Height>
                                                            <MultiBinding Converter="{x:Static conv:MultiplyByAspectRatioConverter.Instance}">
                                                                <Binding Path="$parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).CardSize"/>
                                                                <Binding Path="ClampedAspectRatio"/>
                                                            </MultiBinding>
                                                        </Image.Height>
                                                        <Image.Effect>
                                                            <BlurEffect Radius="{Binding IsBlurred, Converter={StaticResource BoolToBlurRadiusConverter}}" />
                                                        </Image.Effect>
                                                    </Image>
                                                </Panel>
                                            </Border>
                                            <!-- badges -->
                                            <Panel Grid.Row="0" ZIndex="5" IsHitTestVisible="False">
                                                <Panel.Height>
                                                    <MultiBinding Converter="{x:Static conv:MultiplyByAspectRatioConverter.Instance}">
                                                        <Binding Path="$parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).CardSize"/>
                                                        <Binding Path="ClampedAspectRatio"/>
                                                    </MultiBinding>
                                                </Panel.Height>
                                                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                        Margin="0,6,6,0" Padding="5,2" CornerRadius="4"
                                                        Background="#CCDC2626" IsVisible="{Binding IsR18}">
                                                    <TextBlock Text="R-18" FontSize="8" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                                <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                                        Margin="0,0,6,6" Padding="5,2" CornerRadius="4"
                                                        Background="#BB000000">
                                                    <TextBlock Text="{Binding RankChangeDisplay}" FontSize="9"
                                                               FontWeight="SemiBold" Foreground="{Binding RankChangeForeground}"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                            Margin="6,0,0,6" Spacing="3">
                                                    <Border Padding="6,3" CornerRadius="5" Background="#DD000000">
                                                        <TextBlock Text="{Binding Rank, StringFormat='#{0}'}"
                                                                   FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <Border Padding="5,2" CornerRadius="4" Background="#BB000000"
                                                            IsVisible="{Binding IsMultiPage}">
                                                        <TextBlock Text="{Binding PageCount, StringFormat='1/{0}'}"
                                                                   FontSize="9" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                            </Panel>
                                            <CheckBox Grid.Row="0" ZIndex="6"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Top" HorizontalAlignment="Left"
                                                      Margin="6,6,0,0" MinWidth="0" MinHeight="0"
                                                      Click="OnCardCheckboxClicked"/>
                                            <StackPanel Grid.Row="1" Margin="8,5,8,7" Spacing="2"
                                                        IsVisible="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).ShowInfo}">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding Title}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrush}"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <TextBlock Grid.Column="1" FontSize="10"
                                                               Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                               Text="{Binding PageCount, StringFormat='1/{0}'}"
                                                               VerticalAlignment="Center" Margin="4,0,0,0"
                                                               IsVisible="{Binding IsMultiPage}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding UserName}" FontSize="10"
                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                <ItemsControl ItemsSource="{Binding TopTags}" Margin="0,1,0,0"
                                                              IsVisible="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).ShowTags}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <Border Margin="0,1,3,1" Padding="5,2" CornerRadius="3"
                                                                    Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                                    BorderThickness="0" Cursor="Hand"
                                                                    PointerPressed="OnTagChipPressed">
                                                                <Border.Styles>
                                                                    <Style Selector="Border:pointerover">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                    </Style>
                                                                    <Style Selector="Border:pointerover TextBlock">
                                                                        <Setter Property="TextDecorations" Value="Underline"/>
                                                                        <Setter Property="Foreground" Value="#5B8DEF"/>
                                                                    </Style>
                                                                </Border.Styles>
                                                                <TextBlock Text="{Binding}" FontSize="10"
                                                                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    </Panel>
                </ScrollViewer>

                <!-- ── LIST view ── -->
                <ScrollViewer Name="ListScrollViewer"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              AllowAutoHide="False"
                              IsVisible="{Binding IsListView}"
                              ScrollChanged="OnScrollChanged">
                    <ItemsControl ItemsSource="{Binding FilteredItems}" Margin="8,8,8,8"
                                  IsVisible="{Binding FilteredItems.Count}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RankingCardViewModel">
                                <Border Margin="0,0,0,4"
                                        Background="{actipro:ThemeResource Container1BackgroundBrush}"
                                        BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        BoxShadow="0 1 3 0 #20000000" Cursor="Hand"
                                        PointerPressed="OnCardClicked">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="BorderBrush" Value="{actipro:ThemeResource ControlBackgroundBrushSolidAccent}"/>
                                        </Style>
                                    </Border.Styles>
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="6,4">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                  MinWidth="0" MinHeight="0" Margin="0,0,6,0"
                                                  Click="OnCardCheckboxClicked"/>
                                        <!-- Rank badge -->
                                        <Border Grid.Column="1" Padding="7,3" CornerRadius="4"
                                                Background="{actipro:ThemeResource Container2BackgroundBrush}"
                                                Margin="0,0,8,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Rank, StringFormat='#{0}'}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrush}"/>
                                        </Border>
                                        <!-- Title + artist -->
                                        <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                            <TextBlock Text="{Binding UserName}" FontSize="10"
                                                       Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"/>
                                        </StackPanel>
                                        <!-- Date -->
                                        <TextBlock Grid.Column="3" Text="{Binding Date}" FontSize="10"
                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                   VerticalAlignment="Center" Margin="12,0"/>
                                        <!-- Pages -->
                                        <TextBlock Grid.Column="4" Text="{Binding PageCount, StringFormat='1/{0}'}"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                                                   IsVisible="{Binding IsMultiPage}" Margin="0,0,12,0"/>
                                        <!-- Rank change -->
                                        <TextBlock Grid.Column="5" Text="{Binding RankChangeDisplay}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{Binding RankChangeForeground}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Panel>
            </Grid>
        </Border>

        <!-- ══ Row 5: Status bar ══ -->
        <Border Grid.Row="5"
                Background="{actipro:ThemeResource Container1BackgroundBrush}"
                BorderBrush="{actipro:ThemeResource Container1BorderBrush}"
                BorderThickness="0,1,0,0" Padding="14,8">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" FontSize="11"
                           Foreground="{actipro:ThemeResource DefaultForegroundBrushTertiary}"
                           Text="{Binding StatusMessage}" VerticalAlignment="Center"/>

                <!-- Pagination controls at bottom -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,20,0">
                    <!-- Pagination Toggle -->
                    <ToggleButton IsChecked="{Binding UsePagination, Mode=TwoWay}"
                                  CornerRadius="6" Padding="8,4" FontSize="11"
                                  ToolTip.Tip="Toggle pagination (off = show all, on = paginated)">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="📄" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="Pages" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Items per page selector (visible when pagination enabled) -->
                    <ComboBox IsVisible="{Binding UsePagination}"
                              SelectedItem="{Binding ItemsPerPage, Mode=TwoWay}"
                              ItemsSource="{Binding ItemsPerPageOptions}"
                              CornerRadius="6" MinWidth="75" FontSize="11"
                              ToolTip.Tip="Items per page"/>

                    <!-- Page navigation (visible when pagination enabled) -->
                    <StackPanel IsVisible="{Binding UsePagination}" Orientation="Horizontal" Spacing="4">
                        <!-- First page -->
                        <Button Command="{Binding FirstPageCommand}"
                                IsEnabled="{Binding CanGoPrevious}"
                                CornerRadius="6" Padding="8,4" FontSize="11"
                                ToolTip.Tip="Go to first page">|←</Button>

                        <!-- Previous page -->
                        <Button Command="{Binding PreviousPageCommand}"
                                IsEnabled="{Binding CanGoPrevious}"
                                CornerRadius="6" Padding="8,4" FontSize="11"
                                ToolTip.Tip="Previous page">←</Button>

                        <!-- Page input -->
                        <TextBox Text="{Binding GalleryCurrentPage, Mode=TwoWay}"
                                 Width="40"
                                 CornerRadius="6"
                                 FontSize="11"
                                 HorizontalContentAlignment="Center"
                                 VerticalAlignment="Center"
                                 ToolTip.Tip="Enter page number and press Enter to jump"/>

                        <TextBlock Text="/" VerticalAlignment="Center" FontSize="11" Margin="2,0"/>
                        <TextBlock Text="{Binding TotalPages, StringFormat='{}{0}'}" VerticalAlignment="Center" FontSize="11" Margin="0,0,2,0"/>

                        <!-- Next page -->
                        <Button Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding CanGoNext}"
                                CornerRadius="6" Padding="8,4" FontSize="11"
                                ToolTip.Tip="Next page">→</Button>

                        <!-- Last page -->
                        <Button Command="{Binding LastPageCommand}"
                                IsEnabled="{Binding CanGoNext}"
                                CornerRadius="6" Padding="8,4" FontSize="11"
                                ToolTip.Tip="Go to last page">→|</Button>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="2" Content="Load More" CornerRadius="6" Padding="12,5" FontSize="11"
                        Command="{Binding LoadMoreCommand}"
                        IsVisible="{Binding CanLoadMore}"
                        ToolTip.Tip="Load next page"/>
            </Grid>
        </Border>

        <!-- ══ Inline image viewer — FULL-SCREEN overlay ══
             Used when ShowPreview is OFF; when ShowPreview is ON the side panel
             above takes over instead. -->
        <gallery:InlineArtworkViewer Name="RankingsOverlayViewer"
                                     Grid.Row="0" Grid.RowSpan="6"
                                     Margin="0,32,0,0"
                                     ZIndex="10"
                                     DataContext="{Binding GalleryVm}"
                                     IsExpanded="{Binding $parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).IsViewerExpanded}">
            <gallery:InlineArtworkViewer.IsVisible>
                <Binding Path="$parent[UserControl].((vm:EnhancedRankingsViewModel)DataContext).IsViewerExpanded"/>
            </gallery:InlineArtworkViewer.IsVisible>
        </gallery:InlineArtworkViewer>
    </Grid>
</UserControl>
