<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        x:Class="Pixora.Avalonia.Views.Dialogs.SavePresetDialog"
        Title="Save Preset"
        Width="400"
        Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Border Padding="20">
        <StackPanel Spacing="16">
            <TextBlock Text="Save Download Preset" FontSize="16" FontWeight="SemiBold"/>

            <StackPanel Spacing="8">
                <TextBlock Text="Preset Name" FontSize="12"/>
                <TextBox x:Name="PresetNameTextBox"
                         PlaceholderText="e.g., My Favorite Artists"
                         CornerRadius="6"/>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="Description (optional)" FontSize="12"/>
                <TextBox x:Name="DescriptionTextBox"
                         PlaceholderText="Brief description of this preset..."
                         CornerRadius="6"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                <Button Content="Cancel"
                        Click="CancelButton_Click"
                        CornerRadius="6" Padding="12,8"/>
                <Button Content="Save"
                        Click="SaveButton_Click"
                        Classes="accent"
                        CornerRadius="6" Padding="12,8"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
